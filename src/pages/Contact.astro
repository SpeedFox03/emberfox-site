---
import BaseLayout from '../layouts/BaseLayout.astro';
import PhoneLight from 'phosphor-astro/PhoneLight.astro';
import EnvelopeLight from 'phosphor-astro/EnvelopeLight.astro';
import MapPinLight from 'phosphor-astro/MapPinLight.astro';
import PaperPlaneTiltLight from 'phosphor-astro/PaperPlaneTiltLight.astro';
---
<BaseLayout title="Contact" description="Contactez EmberFox pour un devis gratuit">

  <section class="page-hero">
    <div class="container">
      <div class="page-hero-inner">
        <p class="section-pre mono-font fire-text">— Contact</p>
        <h1 class="display-font page-title">Parlons de<br/><span class="fire-text">votre projet</span></h1>
        <p class="page-sub">Devis gratuit, réponse sous 24h. Remplissez le formulaire ou contactez-moi directement.</p>
      </div>
    </div>
    <div class="geo-bg" aria-hidden="true">
      <svg class="geo-svg" viewBox="0 0 500 420" fill="none" xmlns="http://www.w3.org/2000/svg">
        <defs>
          <radialGradient id="netGlow" cx="50%" cy="50%" r="55%">
            <stop offset="0%" stop-color="rgba(255,80,0,0.10)"/>
            <stop offset="100%" stop-color="rgba(255,60,0,0)"/>
          </radialGradient>
        </defs>
        <ellipse cx="250" cy="210" rx="210" ry="190" fill="url(#netGlow)"/>
        <!-- Connection lines from center -->
        <line x1="250" y1="210" x2="108" y2="108" stroke="rgba(255,120,0,0.16)" stroke-width="1"/>
        <line x1="250" y1="210" x2="382" y2="98"  stroke="rgba(255,120,0,0.16)" stroke-width="1"/>
        <line x1="250" y1="210" x2="432" y2="228" stroke="rgba(255,120,0,0.16)" stroke-width="1"/>
        <line x1="250" y1="210" x2="362" y2="332" stroke="rgba(255,120,0,0.16)" stroke-width="1"/>
        <line x1="250" y1="210" x2="138" y2="338" stroke="rgba(255,120,0,0.16)" stroke-width="1"/>
        <line x1="250" y1="210" x2="68"  y2="238" stroke="rgba(255,120,0,0.16)" stroke-width="1"/>
        <line x1="250" y1="210" x2="162" y2="72"  stroke="rgba(255,100,0,0.12)" stroke-width="1"/>
        <line x1="250" y1="210" x2="340" y2="58"  stroke="rgba(255,100,0,0.12)" stroke-width="1"/>
        <!-- Node-to-node secondary lines -->
        <line x1="108" y1="108" x2="162" y2="72"  stroke="rgba(255,100,0,0.10)" stroke-width="0.8"/>
        <line x1="382" y1="98"  x2="340" y2="58"  stroke="rgba(255,100,0,0.10)" stroke-width="0.8"/>
        <line x1="382" y1="98"  x2="432" y2="228" stroke="rgba(255,100,0,0.10)" stroke-width="0.8"/>
        <line x1="432" y1="228" x2="362" y2="332" stroke="rgba(255,100,0,0.10)" stroke-width="0.8"/>
        <line x1="138" y1="338" x2="68"  y2="238" stroke="rgba(255,100,0,0.10)" stroke-width="0.8"/>
        <line x1="108" y1="108" x2="68"  y2="238" stroke="rgba(255,90,0,0.08)"  stroke-width="0.8"/>
        <!-- Outer nodes -->
        <circle cx="108" cy="108" r="5" stroke="rgba(255,130,0,0.28)" stroke-width="1.2" fill="rgba(255,80,0,0.08)"/>
        <circle cx="382" cy="98"  r="5" stroke="rgba(255,130,0,0.28)" stroke-width="1.2" fill="rgba(255,80,0,0.08)"/>
        <circle cx="432" cy="228" r="5" stroke="rgba(255,130,0,0.28)" stroke-width="1.2" fill="rgba(255,80,0,0.08)"/>
        <circle cx="362" cy="332" r="5" stroke="rgba(255,130,0,0.28)" stroke-width="1.2" fill="rgba(255,80,0,0.08)"/>
        <circle cx="138" cy="338" r="5" stroke="rgba(255,130,0,0.28)" stroke-width="1.2" fill="rgba(255,80,0,0.08)"/>
        <circle cx="68"  cy="238" r="5" stroke="rgba(255,130,0,0.28)" stroke-width="1.2" fill="rgba(255,80,0,0.08)"/>
        <circle cx="162" cy="72"  r="4" stroke="rgba(255,110,0,0.20)" stroke-width="1"   fill="rgba(255,80,0,0.06)"/>
        <circle cx="340" cy="58"  r="4" stroke="rgba(255,110,0,0.20)" stroke-width="1"   fill="rgba(255,80,0,0.06)"/>
        <!-- Central node (pulse) -->
        <circle cx="250" cy="210" r="18" stroke="rgba(255,120,0,0.12)" stroke-width="1" fill="none" class="net-ring"/>
        <circle cx="250" cy="210" r="8"  stroke="rgba(255,140,0,0.36)" stroke-width="1.5" fill="rgba(255,80,0,0.12)" class="net-pulse"/>
      </svg>
    </div>
  </section>

  <section class="section contact-section">
    <div class="container contact-grid">

      <!-- FORM -->
      <div class="contact-form-wrap">
        <!-- Remplace YOUR_FORM_ID par ton ID Formspree (formspree.io → New Form) -->
        <form class="contact-form" id="contactForm" action="https://formspree.io/f/xrejjypq" method="POST">
          <div class="form-group">
            <label class="form-label mono-font">Votre nom</label>
            <input type="text" class="form-input" placeholder="Jean Dupont" required />
          </div>
          <div class="form-group">
            <label class="form-label mono-font">Email</label>
            <input type="email" class="form-input" placeholder="jean@exemple.be" required />
          </div>
          <div class="form-group">
            <label class="form-label mono-font">Service souhaité</label>
            <select class="form-input form-select">
              <option value="">Choisir un service</option>
              <option>Site web</option>
              <option>Application sur mesure</option>
              <option>Montage PC</option>
              <option>Dépannage à domicile</option>
              <option>Autre</option>
            </select>
          </div>
          <div class="form-group">
            <label class="form-label mono-font">Message</label>
            <textarea class="form-input form-textarea" placeholder="Décrivez votre projet ou votre problème..." required></textarea>
          </div>
          <button type="submit" class="btn-fire" style="width:100%;justify-content:center;font-size:1.1rem">
            Envoyer ma demande
            <PaperPlaneTiltLight width={18} height={18} />
          </button>
          <div class="form-success" id="formSuccess">
            ✅ Message envoyé ! Je vous réponds sous 24h.
          </div>
        </form>
      </div>

      <!-- INFOS -->
      <div class="contact-infos">
        <div class="info-block">
          <p class="info-label mono-font fire-text">
            <PhoneLight width={14} height={14} />
            Téléphone
          </p>
          <a href="tel:+32498377455" class="info-value display-font">+32 498 37 74 55</a>
          <p class="info-note" style="color:var(--text-muted);font-size:0.85rem">Lun–Sam, 9h–19h</p>
        </div>
        <div class="info-block">
          <p class="info-label mono-font fire-text">
            <EnvelopeLight width={14} height={14} />
            Email
          </p>
          <a href="mailto:contact@emberfox.be" class="info-value display-font">contact@emberfox.be</a>
          <p class="info-note" style="color:var(--text-muted);font-size:0.85rem">Réponse sous 24h</p>
        </div>
        <div class="info-block">
          <p class="info-label mono-font fire-text">
            <MapPinLight width={14} height={14} />
            Zone d'intervention
          </p>
          <p class="info-value display-font" style="font-size:1.5rem">Namur & alentours</p>
          <p class="info-note" style="color:var(--text-muted);font-size:0.85rem">Belgique — Remote possible</p>
        </div>

        <div class="availability-card card">
          <div class="avail-dot"></div>
          <p class="display-font" style="font-size:1.3rem;margin-top:0.5rem">Disponible maintenant</p>
          <p style="color:var(--text-secondary);font-size:0.875rem;margin-top:0.25rem">Prise en charge rapide des urgences</p>
        </div>
      </div>

    </div>
  </section>

</BaseLayout>

<style>
.page-hero { padding: 10rem 0 4rem; position: relative; overflow: hidden; }
.page-hero-inner { max-width: 680px; position: relative; z-index: 2; }
.page-title { font-size: clamp(3rem, 6vw, 5.5rem); line-height: 0.9; margin: 1rem 0 1.5rem; }
.page-sub { color: var(--text-secondary); font-size: 1.1rem; line-height: 1.7; }
.geo-bg { position: absolute; right: -80px; top: 50%; transform: translateY(-50%); width: clamp(320px, 42vw, 560px); height: clamp(320px, 42vw, 560px); pointer-events: none; z-index: 1; }
.geo-svg { width: 100%; height: 100%; overflow: visible; }
.net-pulse { animation: net-beat 2.8s ease-in-out infinite; }
.net-ring   { animation: net-beat 2.8s ease-in-out infinite; animation-delay: 0.3s; }
@keyframes net-beat {
  0%, 100% { opacity: 0.9; }
  50%       { opacity: 0.25; }
}
/* Connection lines stagger-in */
.geo-svg line { animation: net-line-in 0.5s ease both; }
.geo-svg line:nth-of-type(1)  { animation-delay: 0.20s; }
.geo-svg line:nth-of-type(2)  { animation-delay: 0.32s; }
.geo-svg line:nth-of-type(3)  { animation-delay: 0.44s; }
.geo-svg line:nth-of-type(4)  { animation-delay: 0.56s; }
.geo-svg line:nth-of-type(5)  { animation-delay: 0.68s; }
.geo-svg line:nth-of-type(6)  { animation-delay: 0.80s; }
.geo-svg line:nth-of-type(7)  { animation-delay: 0.92s; }
.geo-svg line:nth-of-type(8)  { animation-delay: 1.04s; }
.geo-svg line:nth-of-type(9)  { animation-delay: 1.16s; }
.geo-svg line:nth-of-type(10) { animation-delay: 1.28s; }
.geo-svg line:nth-of-type(11) { animation-delay: 1.40s; }
.geo-svg line:nth-of-type(12) { animation-delay: 1.52s; }
.geo-svg line:nth-of-type(13) { animation-delay: 1.64s; }
.geo-svg line:nth-of-type(14) { animation-delay: 1.76s; }
@keyframes net-line-in { from { opacity: 0; } to { opacity: 1; } }
/* Outer nodes appear after lines */
.geo-svg circle { animation: node-appear 0.35s ease both; }
.geo-svg circle:nth-of-type(1) { animation-delay: 0.55s; }
.geo-svg circle:nth-of-type(2) { animation-delay: 0.70s; }
.geo-svg circle:nth-of-type(3) { animation-delay: 0.85s; }
.geo-svg circle:nth-of-type(4) { animation-delay: 1.00s; }
.geo-svg circle:nth-of-type(5) { animation-delay: 1.15s; }
.geo-svg circle:nth-of-type(6) { animation-delay: 1.30s; }
.geo-svg circle:nth-of-type(7) { animation-delay: 1.45s; }
.geo-svg circle:nth-of-type(8) { animation-delay: 1.60s; }
.geo-svg circle { transform-box: fill-box; transform-origin: center; }
@keyframes node-appear { from { opacity: 0; transform: scale(0.3); } to { opacity: 1; transform: scale(1); } }
@media (max-width: 768px) { .geo-bg { display: none; } }

.contact-section { padding-top: 0; }
.contact-grid { display: grid; grid-template-columns: 1.2fr 1fr; gap: 5rem; align-items: start; }

/* FORM */
.contact-form { display: flex; flex-direction: column; gap: 1.5rem; }
.form-group { display: flex; flex-direction: column; gap: 0.5rem; }
.form-label {
  font-size: 0.75rem;
  letter-spacing: 0.15em;
  color: var(--ember-3);
  display: inline-flex;
  align-items: center;
  gap: 0.35rem;
}
.form-input {
  background: var(--dark-card);
  border: 1px solid var(--dark-border);
  color: var(--text-primary);
  padding: 0.875rem 1rem;
  font-family: 'DM Sans', sans-serif;
  font-size: 0.95rem;
  outline: none;
  transition: border-color 0.2s;
  width: 100%;
  clip-path: polygon(0 0, calc(100% - 8px) 0, 100% 8px, 100% 100%, 8px 100%, 0 calc(100% - 8px));
}
.form-input:focus { border-color: var(--ember-2); }
.form-input::placeholder { color: var(--text-muted); }
.form-select { cursor: pointer; }
.form-select option { background: var(--dark-card); }
.form-textarea { resize: vertical; min-height: 160px; }
.form-success {
  display: none;
  padding: 1rem;
  background: rgba(255,140,0,0.1);
  border: 1px solid rgba(255,140,0,0.3);
  color: var(--ember-3);
  font-size: 0.9rem;
  text-align: center;
}
.form-success.visible { display: block; }

/* INFOS */
.contact-infos { display: flex; flex-direction: column; gap: 2.5rem; padding-top: 0.5rem; }
.info-block { display: flex; flex-direction: column; gap: 0.25rem; }
.info-label {
  font-size: 0.75rem;
  letter-spacing: 0.15em;
  margin-bottom: 0.25rem;
  display: inline-flex;
  align-items: center;
  gap: 0.35rem;
}
.info-value { color: var(--text-primary); text-decoration: none; font-size: 1.8rem; transition: color 0.2s; }
.info-value:hover { color: var(--ember-3); }

.availability-card { padding: 1.5rem; }
.avail-dot {
  width: 10px; height: 10px;
  background: #22c55e;
  border-radius: 50%;
  box-shadow: 0 0 0 4px rgba(34,197,94,0.2);
  animation: avail-pulse 2s ease-in-out infinite;
}
@keyframes avail-pulse {
  0%, 100% { box-shadow: 0 0 0 4px rgba(34,197,94,0.2); }
  50% { box-shadow: 0 0 0 8px rgba(34,197,94,0.1); }
}

@media (max-width: 768px) {
  .contact-grid { grid-template-columns: 1fr; gap: 3rem; }
}
</style>

<script>
const form = document.getElementById('contactForm') as HTMLFormElement | null;
const btn = form?.querySelector('button[type="submit"]') as HTMLButtonElement | null;
const success = document.getElementById('formSuccess');

form?.addEventListener('submit', async (e) => {
  e.preventDefault();
  if (!btn) return;

  const originalText = btn.textContent ?? '';
  btn.disabled = true;
  btn.textContent = 'Envoi en cours…';

  try {
    const res = await fetch(form.action, {
      method: 'POST',
      body: new FormData(form),
      headers: { Accept: 'application/json' },
    });

    if (res.ok) {
      success?.classList.add('visible');
      form.reset();
    } else {
      alert("Une erreur est survenue. Merci de me contacter directement à contact@emberfox.be");
    }
  } catch {
    alert("Erreur réseau. Merci de réessayer ou de me contacter par email.");
  } finally {
    btn.disabled = false;
    btn.textContent = originalText;
  }
});
</script>