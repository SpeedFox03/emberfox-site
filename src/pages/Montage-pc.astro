---
import BaseLayout from '../layouts/BaseLayout.astro';
import MagnifyingGlassLight from 'phosphor-astro/MagnifyingGlassLight.astro';
import ShoppingCartLight from 'phosphor-astro/ShoppingCartLight.astro';
import WrenchLight from 'phosphor-astro/WrenchLight.astro';
import FlaskLight from 'phosphor-astro/FlaskLight.astro';
import HardDriveLight from 'phosphor-astro/HardDriveLight.astro';
import PhoneLight from 'phosphor-astro/PhoneLight.astro';
import ArrowRightLight from 'phosphor-astro/ArrowRightLight.astro';

const configs = [
  {
    title: 'Home Office',
    range: '600€ – 1 000€',
    desc: 'PC fiable pour le travail, la bureautique et la visio.',
    specs: ['Processeur Ryzen 5 ou Core i5', 'RAM 16 Go DDR5', 'SSD NVMe 512 Go', 'Windows 11 Pro', 'Garantie pièces 2 ans'],
  },
  {
    title: 'Gaming',
    range: '1 200€ – 2 500€',
    desc: 'Performance maximale pour les jeux modernes en 1080p à 4K.',
    specs: ['Ryzen 7 / Core i7 dernière gen', 'RAM 32 Go DDR5', 'GPU RTX 4070+', 'SSD NVMe 1 To', 'Refroidissement optimisé'],
    highlight: true,
  },
  {
    title: 'Workstation',
    range: '2 000€ – 5 000€+',
    desc: 'Puissance de calcul pour la création 3D, vidéo et IA.',
    specs: ['Ryzen 9 / Core i9 / Threadripper', 'RAM 64 Go ECC', 'GPU pro ou dual GPU', 'Stockage RAID', 'Support prioritaire'],
  },
];

const included = [
  { icon: MagnifyingGlassLight, title: 'Audit besoins',        desc: 'On discute de votre usage avant de choisir les composants.' },
  { icon: ShoppingCartLight,    title: 'Sélection pièces',     desc: 'Je négocie les meilleurs prix et évite les pièges marketing.' },
  { icon: WrenchLight,          title: 'Montage & câblage',    desc: 'Assemblage soigné, câblage propre, optimisation thermique.' },
  { icon: FlaskLight,           title: 'Tests & benchmarks',   desc: 'Stabilité, températures, performance vérifiées avant livraison.' },
  { icon: HardDriveLight,       title: 'Installation OS',      desc: 'Windows ou Linux installé, drivers à jour, logiciels de base.' },
  { icon: PhoneLight,           title: 'Support post-livraison', desc: 'Je reste disponible pour tout ajustement ou question.' },
];
---
<BaseLayout title="Montage PC" description="Montage de PC sur mesure gaming et workstation — EmberFox">

  <section class="page-hero">
    <div class="container">
      <div class="page-hero-inner">
        <p class="section-pre mono-font fire-text">— Service 03</p>
        <h1 class="display-font page-title">Montage<br/><span class="fire-text">PC</span></h1>
        <p class="page-sub">Un PC monté à la main, pièce par pièce, selon vos besoins et votre budget. Gaming, création, workstation — je sélectionne les composants les mieux adaptés.</p>
        <a href="/emberfox-site/Contact" class="btn-fire">
          Configurer mon PC
          <ArrowRightLight width={16} height={16} />
        </a>
      </div>
    </div>
    <div class="geo-bg" aria-hidden="true">
      <svg class="geo-svg" viewBox="0 0 500 420" fill="none" xmlns="http://www.w3.org/2000/svg">
        <defs>
          <radialGradient id="pcbGlow" cx="50%" cy="50%" r="55%">
            <stop offset="0%" stop-color="rgba(255,80,0,0.10)"/>
            <stop offset="100%" stop-color="rgba(255,60,0,0)"/>
          </radialGradient>
        </defs>
        <ellipse cx="250" cy="210" rx="210" ry="190" fill="url(#pcbGlow)"/>
        <!-- Central chip -->
        <rect x="178" y="152" width="144" height="106" rx="3" stroke="rgba(255,140,0,0.26)" stroke-width="1.5" fill="rgba(255,80,0,0.04)"/>
        <text x="218" y="210" font-family="monospace" font-size="11" fill="rgba(255,140,0,0.28)">CPU</text>
        <!-- Pins left -->
        <line x1="158" y1="173" x2="178" y2="173" stroke="rgba(255,120,0,0.22)" stroke-width="1.2"/>
        <line x1="158" y1="191" x2="178" y2="191" stroke="rgba(255,120,0,0.22)" stroke-width="1.2"/>
        <line x1="158" y1="209" x2="178" y2="209" stroke="rgba(255,120,0,0.22)" stroke-width="1.2"/>
        <line x1="158" y1="227" x2="178" y2="227" stroke="rgba(255,120,0,0.22)" stroke-width="1.2"/>
        <line x1="158" y1="245" x2="178" y2="245" stroke="rgba(255,120,0,0.22)" stroke-width="1.2"/>
        <!-- Pins right -->
        <line x1="322" y1="173" x2="342" y2="173" stroke="rgba(255,120,0,0.22)" stroke-width="1.2"/>
        <line x1="322" y1="191" x2="342" y2="191" stroke="rgba(255,120,0,0.22)" stroke-width="1.2"/>
        <line x1="322" y1="209" x2="342" y2="209" stroke="rgba(255,120,0,0.22)" stroke-width="1.2"/>
        <line x1="322" y1="227" x2="342" y2="227" stroke="rgba(255,120,0,0.22)" stroke-width="1.2"/>
        <line x1="322" y1="245" x2="342" y2="245" stroke="rgba(255,120,0,0.22)" stroke-width="1.2"/>
        <!-- Pins top -->
        <line x1="202" y1="132" x2="202" y2="152" stroke="rgba(255,120,0,0.22)" stroke-width="1.2"/>
        <line x1="222" y1="132" x2="222" y2="152" stroke="rgba(255,120,0,0.22)" stroke-width="1.2"/>
        <line x1="242" y1="132" x2="242" y2="152" stroke="rgba(255,120,0,0.22)" stroke-width="1.2"/>
        <line x1="262" y1="132" x2="262" y2="152" stroke="rgba(255,120,0,0.22)" stroke-width="1.2"/>
        <line x1="282" y1="132" x2="282" y2="152" stroke="rgba(255,120,0,0.22)" stroke-width="1.2"/>
        <line x1="302" y1="132" x2="302" y2="152" stroke="rgba(255,120,0,0.22)" stroke-width="1.2"/>
        <!-- Pins bottom -->
        <line x1="202" y1="258" x2="202" y2="278" stroke="rgba(255,120,0,0.22)" stroke-width="1.2"/>
        <line x1="222" y1="258" x2="222" y2="278" stroke="rgba(255,120,0,0.22)" stroke-width="1.2"/>
        <line x1="242" y1="258" x2="242" y2="278" stroke="rgba(255,120,0,0.22)" stroke-width="1.2"/>
        <line x1="262" y1="258" x2="262" y2="278" stroke="rgba(255,120,0,0.22)" stroke-width="1.2"/>
        <line x1="282" y1="258" x2="282" y2="278" stroke="rgba(255,120,0,0.22)" stroke-width="1.2"/>
        <line x1="302" y1="258" x2="302" y2="278" stroke="rgba(255,120,0,0.22)" stroke-width="1.2"/>
        <!-- PCB traces -->
        <polyline points="158,173 82,173 82,95"   stroke="rgba(255,120,0,0.16)" stroke-width="1.2" fill="none"/>
        <polyline points="158,209 60,209 60,355"   stroke="rgba(255,100,0,0.12)" stroke-width="1.2" fill="none"/>
        <polyline points="158,245 90,245 90,340 440,340" stroke="rgba(255,110,0,0.14)" stroke-width="1.2" fill="none"/>
        <polyline points="342,173 418,173 418,80"  stroke="rgba(255,120,0,0.16)" stroke-width="1.2" fill="none"/>
        <polyline points="342,209 445,209 445,355" stroke="rgba(255,100,0,0.12)" stroke-width="1.2" fill="none"/>
        <polyline points="202,132 202,76 96,76"    stroke="rgba(255,110,0,0.14)" stroke-width="1.2" fill="none"/>
        <polyline points="262,132 262,56 410,56"   stroke="rgba(255,100,0,0.12)" stroke-width="1.2" fill="none"/>
        <polyline points="222,278 222,342 76,342"  stroke="rgba(255,110,0,0.14)" stroke-width="1.2" fill="none"/>
        <polyline points="282,278 282,362 460,362" stroke="rgba(255,100,0,0.12)" stroke-width="1.2" fill="none"/>
        <!-- Junction dots -->
        <circle cx="82"  cy="173" r="3" fill="rgba(255,130,0,0.30)"/>
        <circle cx="82"  cy="95"  r="3" fill="rgba(255,130,0,0.28)"/>
        <circle cx="90"  cy="245" r="3" fill="rgba(255,130,0,0.28)"/>
        <circle cx="418" cy="173" r="3" fill="rgba(255,130,0,0.30)"/>
        <circle cx="202" cy="76"  r="3" fill="rgba(255,110,0,0.24)"/>
        <circle cx="262" cy="56"  r="3" fill="rgba(255,110,0,0.22)"/>
        <circle cx="222" cy="342" r="3" fill="rgba(255,110,0,0.22)"/>
        <!-- Small components -->
        <rect x="54"  y="58" width="42" height="18" rx="2" stroke="rgba(255,110,0,0.18)" stroke-width="1" fill="rgba(255,80,0,0.03)"/>
        <rect x="398" y="330" width="36" height="18" rx="2" stroke="rgba(255,110,0,0.18)" stroke-width="1" fill="rgba(255,80,0,0.03)"/>
        <text x="60"  y="71"  font-family="monospace" font-size="8" fill="rgba(255,120,0,0.22)">RAM</text>
      </svg>
    </div>
  </section>

  <!-- CONFIGS -->
  <section class="section">
    <div class="container">
      <p class="section-pre mono-font fire-text">— Configurations</p>
      <h2 class="display-font" style="font-size:clamp(2rem,4vw,3rem);margin-bottom:0.5rem">Trouvez votre build</h2>
      <div class="fire-divider"></div>
      <div class="configs-grid">
        {configs.map(c => (
          <div class={`config-card card ${c.highlight ? 'config-highlight' : ''}`}>
            {c.highlight && <div class="config-badge mono-font">Best-seller</div>}
            <h3 class="display-font" style="font-size:2rem">{c.title}</h3>
            <div class="config-range fire-text display-font">{c.range}</div>
            <p style="color:var(--text-secondary);font-size:0.9rem;margin:1rem 0 1.5rem">{c.desc}</p>
            <ul class="config-specs">
              {c.specs.map(s => <li><span style="color:var(--ember-3)">▸</span> {s}</li>)}
            </ul>
            <a href="/emberfox-site/Contact" class={c.highlight ? 'btn-fire' : 'btn-outline'} style="margin-top:auto;justify-content:center">Demander un devis</a>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- INCLUDED -->
  <section class="section" style="background:var(--dark-card);border-top:1px solid var(--dark-border);border-bottom:1px solid var(--dark-border)">
    <div class="container">
      <h2 class="display-font" style="font-size:clamp(2rem,4vw,3rem);margin-bottom:2.5rem">Inclus dans chaque build</h2>
      <div class="included-grid">
        {included.map(item => (
          <div class="included-item">
            <item.icon width={24} height={24} class="included-icon" />
            <div>
              <strong style="color:var(--ember-3);display:block;margin-bottom:0.25rem">{item.title}</strong>
              <span style="color:var(--text-secondary);font-size:0.875rem">{item.desc}</span>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

</BaseLayout>

<style>
.page-hero { padding: 10rem 0 5rem; position: relative; overflow: hidden; }
.page-hero-inner { max-width: 680px; position: relative; z-index: 2; }
.page-title { font-size: clamp(4rem, 9vw, 8rem); line-height: 0.9; margin: 1rem 0 1.5rem; }
.page-sub { color: var(--text-secondary); font-size: 1.1rem; line-height: 1.7; margin-bottom: 2.5rem; }
.page-hero-shape {
  position: absolute;
  right: -80px;
  top: 50%;
  transform: translateY(-50%);
  width: clamp(300px, 38vw, 520px);
  height: clamp(300px, 38vw, 520px);
  pointer-events: none;
  z-index: 1;
}
.geo-bg { position: absolute; right: -80px; top: 50%; transform: translateY(-50%); width: clamp(320px, 42vw, 560px); height: clamp(320px, 42vw, 560px); pointer-events: none; z-index: 1; }
.geo-svg { width: 100%; height: 100%; overflow: visible; }
@media (max-width: 768px) { .geo-bg { display: none; } }
/* PCB chip glow */
.geo-svg > rect:first-of-type {
  animation: pcb-chip-glow 3.5s ease-in-out 1s infinite;
}
@keyframes pcb-chip-glow {
  0%, 100% { stroke: rgba(255,140,0,0.26); }
  50%       { stroke: rgba(255,200,0,0.55); filter: drop-shadow(0 0 4px rgba(255,160,0,0.3)); }
}
/* Junction dots sequential pulse */
.geo-svg circle { animation: pcb-dot 2.8s ease-in-out infinite; }
.geo-svg circle:nth-of-type(1) { animation-delay: 0.00s; }
.geo-svg circle:nth-of-type(2) { animation-delay: 0.40s; }
.geo-svg circle:nth-of-type(3) { animation-delay: 0.80s; }
.geo-svg circle:nth-of-type(4) { animation-delay: 1.20s; }
.geo-svg circle:nth-of-type(5) { animation-delay: 1.60s; }
.geo-svg circle:nth-of-type(6) { animation-delay: 2.00s; }
.geo-svg circle:nth-of-type(7) { animation-delay: 2.40s; }
@keyframes pcb-dot {
  0%, 100% { opacity: 1; }
  40%, 60%  { opacity: 0.15; }
}
/* Entrance animation */
.geo-bg { animation: pcb-reveal 0.9s ease 0.1s both; }
@keyframes pcb-reveal {
  from { opacity: 0; transform: translateY(-50%) scale(0.97); }
  to   { opacity: 1; transform: translateY(-50%) scale(1); }
}

.configs-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.5rem; margin-top: 2rem; }
.config-card { display: flex; flex-direction: column; gap: 0; position: relative; padding: 2.5rem; }
.config-highlight { border-color: var(--ember-1) !important; }
.config-highlight::before { opacity: 1 !important; }
.config-badge {
  position: absolute; top: -12px; right: 1.5rem;
  background: var(--gradient-fire); color: #0A0804;
  font-size: 0.7rem; letter-spacing: 0.15em; padding: 0.25rem 0.75rem;
}
.config-range { font-size: 1.3rem; margin-top: 0.5rem; }
.config-specs { list-style: none; display: flex; flex-direction: column; gap: 0.5rem; margin-bottom: 2rem; flex: 1; }
.config-specs li { color: var(--text-secondary); font-size: 0.875rem; display: flex; gap: 0.5rem; }

.included-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 2rem; }
.included-item { display: flex; gap: 1rem; align-items: flex-start; }
.included-icon { color: var(--ember-2); flex-shrink: 0; margin-top: 0.1rem; }

@media (max-width: 768px) {
  .configs-grid { grid-template-columns: 1fr; }
  .included-grid { grid-template-columns: 1fr 1fr; }
}
@media (max-width: 480px) {
  .included-grid { grid-template-columns: 1fr; }
  .config-card { padding: 1.75rem; }
}
</style>