---
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionHeader from '../components/SectionHeader.astro';
import ProcessSteps from '../components/ProcessSteps.astro';
import CTASection from '../components/CTASection.astro';
import ArrowRightLight from 'phosphor-astro/ArrowRightLight.astro';
import ChatLight from 'phosphor-astro/ChatLight.astro';
import ShieldCheckLight from 'phosphor-astro/ShieldCheckLight.astro';
import HammerLight from 'phosphor-astro/HammerLight.astro';
import ClockLight from 'phosphor-astro/ClockLight.astro';

const values = [
  {
    icon: ChatLight,
    title: 'Écoute',
    desc: 'Je commence toujours par comprendre votre besoin réel avant de proposer quoi que ce soit. Pas de solution toute faite.',
  },
  {
    icon: ShieldCheckLight,
    title: 'Transparence',
    desc: 'Tarifs annoncés à l\'avance, délais honnêtes, explications claires — sans jargon inutile, sans surprise sur la facture.',
  },
  {
    icon: HammerLight,
    title: 'Solutions durables',
    desc: 'Je ne bricole pas. L\'objectif est que ça fonctionne sur le long terme, même après ma mission.',
  },
  {
    icon: ClockLight,
    title: 'Réactivité',
    desc: 'Intervention rapide pour le dépannage, livrables respectés pour les projets. Je respecte votre temps.',
  },
];

const steps: [string, string][] = [
  ['Écoute & analyse',    'On discute de votre besoin, de votre budget, de votre contexte. Je pose les bonnes questions.'],
  ['Proposition claire',  'Devis détaillé, délai estimé, approche technique expliquée simplement. Vous savez exactement ce que vous achetez.'],
  ['Réalisation',         'Je travaille, vous suivez l\'avancement. Retours pris en compte, ajustements inclus.'],
  ['Livraison & support', 'Mise en production, formation si besoin, et disponibilité pour la suite.'],
];
---
<BaseLayout title="À propos" description="Qui est EmberFox ? Jordan, freelance IT basé à Namur, Belgique.">

  <section class="page-hero">
    <div class="container">
      <div class="page-hero-inner">
        <p class="section-pre mono-font fire-text">— À propos</p>
        <h1 class="display-font page-title">L'humain<br/>derrière<br/><span class="fire-text">EmberFox</span></h1>
        <p class="page-sub">Freelance informatique basé à Namur, je travaille avec les particuliers et les petites entreprises qui veulent du travail soigné, des explications claires et quelqu'un de disponible.</p>
        <div style="display:flex;gap:1rem;flex-wrap:wrap">
          <a href="/emberfox-site/Projets" class="btn-fire">
            Voir mes projets
            <ArrowRightLight width={16} height={16} />
          </a>
          <a href="/emberfox-site/Contact" class="btn-outline">Me contacter</a>
        </div>
      </div>
    </div>
    <div class="page-deco-bg" aria-hidden="true">
      <svg viewBox="0 0 500 480" fill="none" xmlns="http://www.w3.org/2000/svg">
        <defs>
          <radialGradient id="aboutGlow" cx="50%" cy="50%" r="55%">
            <stop offset="0%" stop-color="rgba(255,80,0,0.10)"/>
            <stop offset="100%" stop-color="rgba(255,60,0,0)"/>
          </radialGradient>
        </defs>
        <ellipse cx="250" cy="240" rx="220" ry="200" fill="url(#aboutGlow)"/>
        <g font-family="'Courier New', monospace" font-size="13">
          <text x="30" y="55"  fill="rgba(255,140,0,0.22)">// profile.json</text>
          <text x="30" y="82"  fill="rgba(255,120,0,0.20)">&#123;</text>
          <text x="50" y="110" fill="rgba(255,140,0,0.22)">"name":       "Jordan",</text>
          <text x="50" y="135" fill="rgba(255,120,0,0.18)">"role":       "Freelance IT & Dev",</text>
          <text x="50" y="160" fill="rgba(255,100,0,0.16)">"location":   "Namur, Belgique",</text>
          <text x="50" y="185" fill="rgba(255,100,0,0.16)">"experience": "5+ ans",</text>
          <text x="50" y="218" fill="rgba(255,140,0,0.22)">"services": [</text>
          <text x="72" y="243" fill="rgba(255,100,0,0.16)">"Sites Web", "Applications",</text>
          <text x="72" y="268" fill="rgba(255,100,0,0.16)">"Montage PC", "Dépannage"</text>
          <text x="50" y="293" fill="rgba(255,140,0,0.22)">],</text>
          <text x="50" y="325" fill="rgba(255,120,0,0.20)">"stack": ["Astro","React","Node"],</text>
          <text x="50" y="358" fill="rgba(255,80,0,0.22)">"available": true,</text>
          <text x="50" y="390" fill="rgba(255,100,0,0.14)">"languages": ["fr", "en"]</text>
          <text x="30" y="420" fill="rgba(255,120,0,0.18)">&#125;</text>
          <text x="30" y="455" fill="rgba(255,80,0,0.10)">_</text>
        </g>
      </svg>
    </div>
  </section>

  <!-- INTRO -->
  <section class="section">
    <div class="container intro-grid">
      <div class="intro-text fade-in-left">
        <SectionHeader pre="Mon histoire">Passionné depuis<br/>toujours</SectionHeader>
        <p style="color:var(--text-secondary);line-height:1.8;margin-bottom:1rem">Passionné d'informatique depuis l'enfance, j'ai transformé cette curiosité en métier. Après une formation en développement et plusieurs années d'expérience en support technique et développement web, j'ai fondé <strong style="color:var(--text-primary)">EmberFox</strong> pour proposer des services IT accessibles, de qualité, aux particuliers et aux petites entreprises de la région namuroise.</p>
        <p style="color:var(--text-secondary);line-height:1.8">Je travaille seul — ce qui signifie que vous avez toujours affaire à la même personne, du premier appel à la livraison finale. Pas d'intermédiaire, pas de délégation, pas de mauvaise surprise.</p>
      </div>
      <div class="intro-stats fade-in-right">
        {[
          ['5+', 'années d\'expérience'],
          ['30+', 'projets livrés'],
          ['100%', 'clients satisfaits'],
          ['0', 'mauvaise surprise'],
        ].map(([val, label]) => (
          <div class="stat-block">
            <div class="stat-val fire-text display-font">{val}</div>
            <div class="stat-label" style="color:var(--text-secondary);font-size:0.875rem">{label}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- VALUES -->
  <section class="section" style="background:var(--dark-card);border-top:1px solid var(--dark-border);border-bottom:1px solid var(--dark-border)">
    <div class="container">
      <SectionHeader pre="Ce qui me guide">Mes valeurs</SectionHeader>
      <div class="values-grid">
        {values.map(v => (
          <div class="value-card card">
            <v.icon width={28} height={28} class="value-icon" />
            <h3 class="display-font" style="font-size:1.4rem;color:var(--ember-3);margin-top:0.75rem">{v.title}</h3>
            <p style="color:var(--text-secondary);font-size:0.875rem;margin-top:0.35rem;line-height:1.65">{v.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- HOW I WORK -->
  <section class="section">
    <div class="container">
      <p class="section-pre mono-font fire-text">— Process</p>
      <h2 class="display-font" style="font-size:clamp(2rem,4vw,3rem);margin-bottom:2.5rem">Comment je travaille</h2>
      <ProcessSteps steps={steps} />
    </div>
  </section>

  <!-- CTA -->
  <CTASection centered>
    <p class="section-pre mono-font fire-text" style="justify-content:center;display:flex">— Parlons-nous</p>
    <h2 class="display-font" style="font-size:clamp(2rem,4vw,3rem);margin-bottom:1rem">Prêt à démarrer ?</h2>
    <p style="color:var(--text-secondary);line-height:1.8;margin-bottom:2rem">Que ce soit pour un devis, une question ou juste pour voir si on est sur la même longueur d'onde — je réponds toujours.</p>
    <div style="display:flex;gap:1rem;justify-content:center;flex-wrap:wrap">
      <a href="/emberfox-site/Contact" class="btn-fire">
        Prendre contact
        <ArrowRightLight width={16} height={16} />
      </a>
      <a href="/emberfox-site/Projets" class="btn-outline">Voir les projets</a>
    </div>
  </CTASection>

</BaseLayout>

<style>
.page-title { font-size: clamp(3rem, 5.5vw, 5rem); line-height: 0.95; margin: 1rem 0 1.5rem; }
.page-deco-bg g > text { animation: about-line-in 0.4s ease both; }
.page-deco-bg g > text:nth-child(1)  { animation-delay: 0.20s; }
.page-deco-bg g > text:nth-child(2)  { animation-delay: 0.40s; }
.page-deco-bg g > text:nth-child(3)  { animation-delay: 0.58s; }
.page-deco-bg g > text:nth-child(4)  { animation-delay: 0.74s; }
.page-deco-bg g > text:nth-child(5)  { animation-delay: 0.90s; }
.page-deco-bg g > text:nth-child(6)  { animation-delay: 1.06s; }
.page-deco-bg g > text:nth-child(7)  { animation-delay: 1.25s; }
.page-deco-bg g > text:nth-child(8)  { animation-delay: 1.42s; }
.page-deco-bg g > text:nth-child(9)  { animation-delay: 1.58s; }
.page-deco-bg g > text:nth-child(10) { animation-delay: 1.74s; }
.page-deco-bg g > text:nth-child(11) { animation-delay: 1.90s; }
.page-deco-bg g > text:nth-child(12) { animation-delay: 2.08s; }
.page-deco-bg g > text:nth-child(13) { animation-delay: 2.26s; }
.page-deco-bg g > text:nth-child(14) { animation-delay: 2.50s; }
.page-deco-bg g > text:nth-child(15) { animation-delay: 2.70s; }
@keyframes about-line-in { from { opacity: 0; } to { opacity: 1; } }

.intro-grid { display: grid; grid-template-columns: 1.2fr 1fr; gap: 5rem; align-items: start; }
.intro-stats { display: grid; grid-template-columns: 1fr 1fr; gap: 1.5rem; }
.stat-block {
  background: var(--dark-card); border: 1px solid var(--dark-border); padding: 1.5rem;
  clip-path: polygon(0 0, calc(100% - 12px) 0, 100% 12px, 100% 100%, 12px 100%, 0 calc(100% - 12px));
}
.stat-val { font-size: 2.5rem; line-height: 1; margin-bottom: 0.35rem; }

.values-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 1.25rem; margin-top: 2rem; }
.value-card { padding: 1.75rem; }
.value-icon { color: var(--ember-2); opacity: 0.85; }

@media (max-width: 768px) {
  .intro-grid { grid-template-columns: 1fr; gap: 2.5rem; }
  .values-grid { grid-template-columns: 1fr 1fr; }
}
@media (max-width: 480px) {
  .page-title { font-size: clamp(2.8rem, 10vw, 4rem); }
  .values-grid { grid-template-columns: 1fr; }
  .intro-stats { grid-template-columns: 1fr 1fr; }
  .stat-block { padding: 1.25rem; }
}
</style>
