---
import BaseLayout from '../layouts/BaseLayout.astro';
import ProcessSteps from '../components/ProcessSteps.astro';
import CheckCircleLight from 'phosphor-astro/CheckCircleLight.astro';
import ArrowRightLight from 'phosphor-astro/ArrowRightLight.astro';

const offers = [
  { title: 'Site Vitrine', price: 'À partir de 800€', features: ['Design sur mesure', 'Responsive mobile', 'SEO de base', '3 pages', 'Formulaire de contact', 'Mise en ligne incluse'] },
  { title: 'Site Pro', price: 'À partir de 1 500€', features: ['Tout du Vitrine', 'Jusqu\'à 10 pages', 'Blog intégré', 'SEO avancé', 'Google Analytics', 'Optimisation performance'], highlight: true },
  { title: 'E-commerce', price: 'À partir de 2 500€', features: ['Boutique en ligne', 'Paiement sécurisé', 'Gestion produits', 'Tableau de bord', 'Intégrations logistique', 'Formation incluse'] },
];

const techs = ['Astro', 'Next.js', 'WordPress', 'Shopify', 'Tailwind CSS', 'Figma', 'Vercel', 'Netlify'];

const processSteps: [string, string][] = [
  ['Brief',         "On discute de votre projet, vos besoins, votre cible et votre identité."],
  ['Maquette',      "Je conçois les wireframes et la charte graphique pour votre validation."],
  ['Développement', "Je code votre site avec les meilleures technologies du marché."],
  ['Livraison',     "Tests, mise en ligne, formation et suivi post-lancement."],
];
---
<BaseLayout title="Sites Web" description="Création de sites web professionnels sur mesure — EmberFox">

  <!-- HERO PAGE -->
  <section class="page-hero">
    <div class="container">
      <div class="page-hero-inner">
        <p class="section-pre mono-font fire-text">— Service 01</p>
        <h1 class="display-font page-title">Sites<br/><span class="fire-text">Web</span></h1>
        <p class="page-sub">Des sites qui ne passent pas inaperçus. Du design au code, je crée des expériences web qui reflètent votre identité et convertissent vos visiteurs.</p>
        <a href="/emberfox-site/Contact" class="btn-fire">
          Demander un devis
          <ArrowRightLight width={16} height={16} />
        </a>
      </div>
    </div>
    <div class="page-deco-bg" aria-hidden="true">
      <svg viewBox="0 0 500 420" fill="none" xmlns="http://www.w3.org/2000/svg">
        <defs>
          <radialGradient id="wfGlow" cx="50%" cy="50%" r="55%">
            <stop offset="0%" stop-color="rgba(255,80,0,0.10)"/>
            <stop offset="100%" stop-color="rgba(255,60,0,0)"/>
          </radialGradient>
        </defs>
        <ellipse cx="250" cy="210" rx="210" ry="190" fill="url(#wfGlow)"/>
        <rect x="35" y="50" width="430" height="320" rx="5" stroke="rgba(255,130,0,0.18)" stroke-width="1.2" fill="none"/>
        <rect x="35" y="50" width="430" height="34" rx="5" stroke="rgba(255,130,0,0.16)" stroke-width="1" fill="rgba(255,80,0,0.04)"/>
        <line x1="35" y1="84" x2="465" y2="84" stroke="rgba(255,120,0,0.12)" stroke-width="1"/>
        <circle cx="60"  cy="67" r="5" stroke="rgba(255,120,0,0.24)" stroke-width="1" fill="none"/>
        <circle cx="78"  cy="67" r="5" stroke="rgba(255,120,0,0.24)" stroke-width="1" fill="none"/>
        <circle cx="96"  cy="67" r="5" stroke="rgba(255,120,0,0.24)" stroke-width="1" fill="none"/>
        <rect x="120" y="56" width="220" height="16" rx="3" stroke="rgba(255,100,0,0.14)" stroke-width="1" fill="none"/>
        <line x1="35" y1="114" x2="465" y2="114" stroke="rgba(255,110,0,0.10)" stroke-width="1"/>
        <line x1="60"  y1="99" x2="104" y2="99" stroke="rgba(255,130,0,0.20)" stroke-width="2"/>
        <line x1="122" y1="99" x2="162" y2="99" stroke="rgba(255,100,0,0.14)" stroke-width="2"/>
        <line x1="180" y1="99" x2="220" y2="99" stroke="rgba(255,100,0,0.14)" stroke-width="2"/>
        <line x1="380" y1="99" x2="444" y2="99" stroke="rgba(255,140,0,0.22)" stroke-width="2.5"/>
        <rect x="55" y="128" width="230" height="88" rx="2" stroke="rgba(255,120,0,0.13)" stroke-width="1" fill="none"/>
        <line x1="72" y1="150" x2="244" y2="150" stroke="rgba(255,130,0,0.22)" stroke-width="3"/>
        <line x1="72" y1="164" x2="200" y2="164" stroke="rgba(255,100,0,0.14)" stroke-width="1.5"/>
        <line x1="72" y1="176" x2="220" y2="176" stroke="rgba(255,100,0,0.12)" stroke-width="1.5"/>
        <line x1="72" y1="188" x2="172" y2="188" stroke="rgba(255,100,0,0.12)" stroke-width="1.5"/>
        <rect x="72" y="198" width="62" height="12" rx="2" stroke="rgba(255,140,0,0.24)" stroke-width="1" fill="rgba(255,80,0,0.06)"/>
        <rect x="304" y="128" width="147" height="88" rx="2" stroke="rgba(255,100,0,0.12)" stroke-width="1" fill="rgba(255,80,0,0.03)"/>
        <line x1="304" y1="172" x2="451" y2="172" stroke="rgba(255,90,0,0.08)" stroke-width="1"/>
        <line x1="378" y1="128" x2="378" y2="216" stroke="rgba(255,90,0,0.08)" stroke-width="1"/>
        <rect x="55"  y="236" width="116" height="70" rx="2" stroke="rgba(255,110,0,0.13)" stroke-width="1" fill="none"/>
        <rect x="192" y="236" width="116" height="70" rx="2" stroke="rgba(255,110,0,0.13)" stroke-width="1" fill="none"/>
        <rect x="329" y="236" width="117" height="70" rx="2" stroke="rgba(255,110,0,0.13)" stroke-width="1" fill="none"/>
        <line x1="70"  y1="255" x2="152" y2="255" stroke="rgba(255,110,0,0.16)" stroke-width="1.5"/>
        <line x1="70"  y1="267" x2="138" y2="267" stroke="rgba(255,90,0,0.10)"  stroke-width="1"/>
        <line x1="207" y1="255" x2="289" y2="255" stroke="rgba(255,110,0,0.16)" stroke-width="1.5"/>
        <line x1="207" y1="267" x2="275" y2="267" stroke="rgba(255,90,0,0.10)"  stroke-width="1"/>
        <line x1="344" y1="255" x2="426" y2="255" stroke="rgba(255,110,0,0.16)" stroke-width="1.5"/>
        <line x1="344" y1="267" x2="412" y2="267" stroke="rgba(255,90,0,0.10)"  stroke-width="1"/>
        <line x1="35" y1="326" x2="465" y2="326" stroke="rgba(255,90,0,0.10)" stroke-width="1"/>
        <rect x="35" y="326" width="430" height="44" rx="5" stroke="rgba(255,80,0,0.08)" stroke-width="1" fill="rgba(255,70,0,0.02)"/>
      </svg>
    </div>
  </section>

  <!-- PROCESS -->
  <section class="section">
    <div class="container">
      <h2 class="display-font" style="font-size:clamp(2rem,4vw,3rem);margin-bottom:3rem">Comment ça marche ?</h2>
      <ProcessSteps steps={processSteps} />
    </div>
  </section>

  <!-- OFFERS -->
  <section class="section" style="background:var(--dark-card);border-top:1px solid var(--dark-border);border-bottom:1px solid var(--dark-border)">
    <div class="container">
      <h2 class="display-font" style="font-size:clamp(2rem,4vw,3rem);margin-bottom:0.5rem">Formules</h2>
      <div class="fire-divider"></div>
      <div class="offers-grid">
        {offers.map(o => (
          <div class={`offer-wrapper ${o.highlight ? 'offer-wrapper-highlight' : ''}`}>
            {o.highlight && <div class="offer-badge mono-font">Populaire</div>}
            <div class={`offer-card card ${o.highlight ? 'offer-highlight' : ''}`}>
              <h3 class="display-font" style="font-size:1.8rem;color:var(--text-primary)">{o.title}</h3>
              <div class="offer-price fire-text display-font">{o.price}</div>
              <ul class="offer-features">
                {o.features.map(f => (
                  <li>
                    <CheckCircleLight width={14} height={14} class="feature-check" />
                    {f}
                  </li>
                ))}
              </ul>
              <a href="/emberfox-site/Contact" class={o.highlight ? 'btn-fire' : 'btn-outline'} style="width:100%;justify-content:center">Choisir cette formule</a>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- TECH -->
  <section class="section">
    <div class="container">
      <h2 class="display-font" style="font-size:clamp(2rem,4vw,3rem);margin-bottom:2rem">Technologies utilisées</h2>
      <div class="tech-grid">
        {techs.map(t => (
          <div class="tech-pill mono-font">{t}</div>
        ))}
      </div>
    </div>
  </section>

</BaseLayout>

<style>
.page-title { font-size: clamp(4rem, 8vw, 7rem); line-height: 0.9; margin: 1rem 0 1.5rem; }
.page-deco-bg { animation: wf-reveal 1.1s cubic-bezier(0.22,0.61,0.36,1) 0.15s both; }
@keyframes wf-reveal {
  from { opacity: 0; clip-path: inset(0 0 100% 0); }
  to   { opacity: 1; clip-path: inset(0); }
}

.offers-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.5rem; margin-top: 2rem; overflow: visible; }
.offer-wrapper { position: relative; overflow: visible; }
.offer-wrapper:hover .offer-badge { transform: translateY(-4px); box-shadow: 0 8px 20px rgba(255,69,0,0.4); }
.offer-card { position: relative; display: flex; flex-direction: column; gap: 1.25rem; overflow: visible; height: 100%; }
.offer-highlight { padding-top: 1.5rem; border-color: var(--ember-1) !important; }
.offer-highlight::before { opacity: 1 !important; }
.offer-badge {
  position: absolute; top: -12px; right: 1.5rem;
  background: var(--gradient-fire); color: #0A0804;
  font-size: 0.7rem; letter-spacing: 0.15em; padding: 0.25rem 0.75rem;
  transition: transform 0.3s ease, box-shadow 0.3s ease; z-index: 999;
}
.offer-price { font-size: 1.5rem; color: var(--ember-3); }
.offer-features { list-style: none; display: flex; flex-direction: column; gap: 0.6rem; flex: 1; }
.offer-features li { font-size: 0.9rem; color: var(--text-secondary); display: flex; align-items: center; gap: 0.5rem; }
.feature-check { color: var(--ember-3); flex-shrink: 0; }

.tech-grid { display: flex; flex-wrap: wrap; gap: 0.75rem; }
.tech-pill {
  padding: 0.5rem 1.25rem; border: 1px solid var(--dark-border);
  color: var(--text-secondary); font-size: 0.85rem; letter-spacing: 0.05em;
  transition: border-color 0.2s, color 0.2s;
}
.tech-pill:hover { border-color: var(--ember-2); color: var(--ember-3); }

@media (max-width: 768px) { .offers-grid { grid-template-columns: 1fr; } }
@media (max-width: 480px) { .tech-grid { gap: 0.5rem; } .tech-pill { font-size: 0.78rem; padding: 0.4rem 0.875rem; } }
</style>
