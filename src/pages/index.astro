---
import BaseLayout from '../layouts/BaseLayout.astro';
import { Image } from 'astro:assets';
import logo from '../images/logo2.png';
import GlobeLight from 'phosphor-astro/GlobeLight.astro';
import LightningLight from 'phosphor-astro/LightningLight.astro';
import DesktopLight from 'phosphor-astro/DesktopLight.astro';
import WrenchLight from 'phosphor-astro/WrenchLight.astro';
import ArrowRightLight from 'phosphor-astro/ArrowRightLight.astro';
import PhoneLight from 'phosphor-astro/PhoneLight.astro';
import TargetLight from 'phosphor-astro/TargetLight.astro';
import HandshakeLight from 'phosphor-astro/HandshakeLight.astro';
import HeartLight from 'phosphor-astro/HeartLight.astro';

const services = [
  {
    icon: GlobeLight,
    title: 'Sites Web',
    desc: 'Des sites vitrines, e-commerce et landing pages qui convertissent.',
    href: '/Sites-web',
    tag: 'Design & Dev',
    num: '01'
  },
  {
    icon: LightningLight,
    title: 'Applications',
    desc: 'Des apps métier sur mesure adaptées à vos besoins spécifiques.',
    href: '/Applications',
    tag: 'Sur mesure',
    num: '02'
  },
  {
    icon: DesktopLight,
    title: 'Montage PC',
    desc: 'Configurations gaming, workstation et home office sur mesure.',
    href: '/Montage-pc',
    tag: 'Hardware',
    num: '03'
  },
  {
    icon: WrenchLight,
    title: 'Dépannage',
    desc: 'Intervention rapide chez vous — virus, panne, configuration.',
    href: '/Depannage',
    tag: 'Particuliers',
    num: '04'
  },
];

const stats = [
  { value: '150+', label: 'Clients satisfaits' },
  { value: '8 ans', label: "D'expérience" },
  { value: '24h', label: 'Délai de réponse' },
  { value: '100%', label: 'Passion tech' },
];

const whyItems = [
  { icon: LightningLight, title: 'Réactivité', desc: "Réponse sous 24h garantie, intervention rapide pour les urgences." },
  { icon: TargetLight,    title: 'Sur mesure', desc: "Pas de templates génériques — chaque solution est pensée pour vous." },
  { icon: HandshakeLight, title: 'Transparent', desc: "Devis clair, suivi régulier, aucune mauvaise surprise." },
  { icon: HeartLight,     title: 'Passionné',  desc: "La technologie est ma passion depuis toujours — ça se sent." },
];
---
<BaseLayout title="Accueil" description="EmberFox — Solutions informatiques sur mesure en Belgique">

  <!-- HERO -->
  <section class="hero">
    <div class="hero-bg">
      <div class="hero-orb orb-1"></div>
      <div class="hero-orb orb-2"></div>
      <div class="hero-orb orb-3"></div>
      <div class="hero-grid"></div>
      <div class="hero-scanline"></div>
    </div>

    <div class="container hero-content">
      <div class="hero-copy">
        <div class="hero-badge mono-font">
          <span class="badge-dot"></span>
          Disponible · Namur & alentours
        </div>
        <h1 class="hero-title display-font">
          L'informatique<br/>
          <span class="fire-text">qui embrase</span><br/>
          vos projets
        </h1>
        <p class="hero-sub">
          Sites web, applications, montage PC, dépannage — EmberFox vous accompagne
          avec expertise et passion dans tous vos besoins informatiques.
        </p>
        <div class="hero-actions">
          <a href="/Contact" class="btn-fire">
            Démarrer un projet
            <ArrowRightLight width={16} height={16} />
          </a>
          <a href="#services" class="btn-outline">Voir les services</a>
        </div>
        <div class="hero-stats">
          {stats.map(s => (
            <div class="stat">
              <span class="stat-value fire-text display-font">{s.value}</span>
              <span class="stat-label">{s.label}</span>
            </div>
          ))}
        </div>
      </div>

      <div class="hero-visual">
        <div class="video-frame">
          <div class="video-frame-corner tl"></div>
          <div class="video-frame-corner tr"></div>
          <div class="video-frame-corner bl"></div>
          <div class="video-frame-corner br"></div>
          <div class="video-placeholder">
            <div class="placeholder-inner">
              <div class="placeholder-icon">
                <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1">
                  <polygon points="5 3 19 12 5 21 5 3"/>
                </svg>
              </div>
              <span class="mono-font placeholder-text">VIDÉO À VENIR</span>
              <div class="placeholder-bar">
                <div class="placeholder-bar-fill"></div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Logo flottant PNG -->
    <div class="hero-logo-float" aria-hidden="true">
      <Image src={logo} alt="" width={480} height={640} class="fox-float-img" />
    </div>
  </section>

  <!-- SERVICES -->
  <section class="section" id="services">
    <div class="container">
      <div class="section-header">
        <p class="section-pre mono-font fire-text">— Services</p>
        <h2 class="display-font" style="font-size:clamp(2.5rem,5vw,4rem)">Ce que je propose</h2>
        <div class="fire-divider"></div>
        <p class="section-desc">Une expertise complète pour répondre à tous vos besoins numériques et matériels.</p>
      </div>
      <div class="services-grid">
        {services.map(s => (
          <a href={s.href} class="service-card card">
            <div class="service-header">
              <div class="service-tag mono-font">{s.tag}</div>
              <div class="service-num display-font">{s.num}</div>
            </div>
            <div class="service-icon-wrap">
              <s.icon width={32} height={32} class="service-icon" />
            </div>
            <h3 class="display-font" style="font-size:2rem;margin:0.75rem 0 0.5rem">{s.title}</h3>
            <p style="color:var(--text-secondary);font-size:0.95rem;flex:1">{s.desc}</p>
            <div class="service-footer">
              <span class="service-arrow">
                <ArrowRightLight width={20} height={20} />
              </span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- WHY -->
  <section class="section why-section">
    <div class="container">
      <div class="why-grid">
        <div class="why-left">
          <p class="section-pre mono-font fire-text">— Pourquoi EmberFox ?</p>
          <h2 class="display-font" style="font-size:clamp(2.5rem,4vw,3.5rem)">Expertise locale,<br/>passion globale</h2>
          <div class="fire-divider"></div>
          <p style="color:var(--text-secondary);margin-bottom:2rem;line-height:1.8">
            Basé à Namur, j'interviens rapidement chez vous ou à distance.
            Chaque projet est traité avec la même exigence et le même feu sacré.
          </p>
          <a href="/Contact" class="btn-fire">
            Me contacter
            <ArrowRightLight width={16} height={16} />
          </a>
        </div>
        <div class="why-right">
          {whyItems.map((item, i) => (
            <div class="why-item">
              <div class="why-num mono-font">{String(i + 1).padStart(2, '0')}</div>
              <div class="why-content">
                <strong class="display-font" style="font-size:1.3rem;color:var(--ember-3)">{item.title}</strong>
                <p style="color:var(--text-secondary);font-size:0.9rem;margin-top:0.25rem">{item.desc}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- CTA BAND -->
  <section class="cta-band">
    <div class="container">
      <div class="cta-inner">
        <div class="cta-glow"></div>
        <div>
          <p class="mono-font fire-text" style="font-size:0.8rem;letter-spacing:0.2em;margin-bottom:0.5rem">— Prêt à démarrer ?</p>
          <h2 class="display-font" style="font-size:clamp(2rem,4vw,3rem)">Lançons votre projet</h2>
          <p style="color:var(--text-secondary);margin-top:0.25rem">Devis gratuit · Réponse sous 24h</p>
        </div>
        <div class="cta-actions">
          <a href="/Contact" class="btn-fire">
            Demander un devis
            <ArrowRightLight width={16} height={16} />
          </a>
          <a href="tel:+32000000000" class="btn-outline">
            <PhoneLight width={16} height={16} />
            Appeler
          </a>
        </div>
      </div>
    </div>
  </section>

</BaseLayout>

<style>
/* HERO */
.hero {
  min-height: 100vh;
  display: flex;
  align-items: center;
  position: relative;
  overflow: hidden;
  padding: 8rem 0 4rem;
}
.hero-bg {
  position: absolute;
  inset: 0;
  pointer-events: none;
}
.hero-orb {
  position: absolute;
  border-radius: 50%;
  filter: blur(80px);
  opacity: 0.12;
}
.orb-1 { width: 700px; height: 700px; background: var(--ember-1); top: -200px; left: -100px; }
.orb-2 { width: 500px; height: 500px; background: var(--ember-3); bottom: -150px; right: 20%; }
.orb-3 { width: 300px; height: 300px; background: var(--ember-gold); top: 30%; right: 10%; }
.hero-grid {
  position: absolute; inset: 0;
  background-image:
    linear-gradient(rgba(255,70,0,0.04) 1px, transparent 1px),
    linear-gradient(90deg, rgba(255,70,0,0.04) 1px, transparent 1px);
  background-size: 60px 60px;
}
.hero-scanline {
  position: absolute;
  top: 0; left: 0; right: 0;
  height: 2px;
  background: linear-gradient(90deg, transparent, rgba(255,100,0,0.3), transparent);
  animation: scan 6s linear infinite;
}
@keyframes scan {
  0% { top: 0; opacity: 1; }
  90% { opacity: 0.3; }
  100% { top: 100%; opacity: 0; }
}

.hero-content {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 4rem;
  align-items: center;
  position: relative;
  z-index: 2;
}
.hero-badge {
  display: inline-flex;
  align-items: center;
  gap: 0.5rem;
  font-size: 0.78rem;
  color: var(--ember-3);
  border: 1px solid rgba(255,140,0,0.25);
  padding: 0.4rem 1rem;
  margin-bottom: 2rem;
  letter-spacing: 0.12em;
  animation: badge-in 0.6s ease both;
}
@keyframes badge-in {
  from { opacity: 0; transform: translateY(-8px); }
  to { opacity: 1; transform: translateY(0); }
}
.badge-dot {
  width: 6px; height: 6px;
  background: #22c55e;
  border-radius: 50%;
  box-shadow: 0 0 0 3px rgba(34,197,94,0.2);
  animation: blink 2s ease-in-out infinite;
}
@keyframes blink {
  0%, 100% { opacity: 1; box-shadow: 0 0 0 3px rgba(34,197,94,0.2); }
  50% { opacity: 0.4; box-shadow: 0 0 0 6px rgba(34,197,94,0.08); }
}
.hero-title {
  font-size: clamp(3.5rem, 7vw, 6.5rem);
  line-height: 0.92;
  margin-bottom: 1.5rem;
  color: var(--text-primary);
  animation: title-in 0.8s ease 0.1s both;
}
@keyframes title-in {
  from { opacity: 0; transform: translateY(20px); }
  to { opacity: 1; transform: translateY(0); }
}
.hero-sub {
  color: var(--text-secondary);
  font-size: 1.05rem;
  max-width: 500px;
  margin-bottom: 2.5rem;
  line-height: 1.8;
  animation: title-in 0.8s ease 0.2s both;
}
.hero-actions {
  display: flex;
  gap: 1rem;
  flex-wrap: wrap;
  margin-bottom: 4rem;
  animation: title-in 0.8s ease 0.3s both;
}
.hero-stats {
  display: flex;
  gap: 2.5rem;
  padding-top: 2rem;
  border-top: 1px solid var(--dark-border);
  animation: title-in 0.8s ease 0.4s both;
}
.stat { display: flex; flex-direction: column; }
.stat-value { font-size: 2rem; line-height: 1; }
.stat-label { font-size: 0.75rem; color: var(--text-muted); margin-top: 0.25rem; letter-spacing: 0.05em; }

/* HERO VISUAL */
.hero-visual { position: relative; }
.video-frame {
  position: relative;
  width: 100%;
  max-width: 540px;
  aspect-ratio: 16 / 9;
  background: var(--dark-card);
  border: 1px solid var(--dark-border);
  clip-path: polygon(0 0, calc(100% - 22px) 0, 100% 22px, 100% 100%, 22px 100%, 0 calc(100% - 22px));
  overflow: hidden;
  animation: title-in 0.8s ease 0.5s both;
}
.video-frame-corner {
  position: absolute;
  width: 16px; height: 16px;
  z-index: 3;
}
.video-frame-corner.tl { top: 0; left: 0; border-top: 2px solid var(--ember-2); border-left: 2px solid var(--ember-2); }
.video-frame-corner.tr { top: 0; right: 0; border-top: 2px solid var(--ember-2); border-right: 2px solid var(--ember-2); }
.video-frame-corner.bl { bottom: 0; left: 0; border-bottom: 2px solid var(--ember-2); border-left: 2px solid var(--ember-2); }
.video-frame-corner.br { bottom: 0; right: 0; border-bottom: 2px solid var(--ember-2); border-right: 2px solid var(--ember-2); }
.video-placeholder {
  width: 100%; height: 100%;
  display: flex; align-items: center; justify-content: center;
  background:
    linear-gradient(rgba(255,70,0,0.03) 1px, transparent 1px),
    linear-gradient(90deg, rgba(255,70,0,0.03) 1px, transparent 1px),
    var(--dark-card);
  background-size: 32px 32px;
}
.placeholder-inner { text-align: center; display: flex; flex-direction: column; align-items: center; gap: 1rem; }
.placeholder-icon { color: var(--ember-1); opacity: 0.5; }
.placeholder-text { color: var(--text-muted); font-size: 0.75rem; letter-spacing: 0.2em; }
.placeholder-bar { width: 80px; height: 2px; background: var(--dark-border); }
.placeholder-bar-fill { width: 40%; height: 100%; background: var(--gradient-fire); animation: bar-pulse 2s ease-in-out infinite; }
@keyframes bar-pulse { 0%, 100% { width: 30%; } 50% { width: 70%; } }

/* FLOAT LOGO */
.hero-logo-float {
  position: absolute;
  right: 3%;
  top: 50%;
  transform: translateY(-50%);
  pointer-events: none;
  z-index: 1;
}
.fox-float-img {
  width: 480px; height: 480px;
  object-fit: contain;
  opacity: 0.18;
  animation: fox-float 7s ease-in-out infinite;
  filter: drop-shadow(0 0 30px rgba(255, 100, 0, 0.2));
}
@keyframes fox-float {
  0%, 100% { transform: translateY(0px) rotate(0deg); }
  33% { transform: translateY(-18px) rotate(0.5deg); }
  66% { transform: translateY(8px) rotate(-0.3deg); }
}

/* SERVICES */
.section-header { margin-bottom: 3rem; }
.section-pre { font-size: 0.78rem; letter-spacing: 0.22em; margin-bottom: 0.5rem; }
.section-desc { color: var(--text-secondary); max-width: 480px; margin-top: 1rem; }

.services-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 1.25rem;
}
.service-card {
  text-decoration: none;
  color: inherit;
  display: flex;
  flex-direction: column;
  padding: 2.5rem;
  min-height: 280px;
}
.service-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 1.5rem;
}
.service-tag {
  font-size: 0.68rem;
  letter-spacing: 0.2em;
  color: var(--ember-3);
  text-transform: uppercase;
}
.service-num {
  font-size: 1rem;
  color: var(--text-muted);
  transition: color 0.3s;
}
.service-card:hover .service-num { color: var(--ember-3); }
.service-icon-wrap { }
.service-icon {
  color: var(--ember-2);
  opacity: 0.7;
}
.service-footer {
  margin-top: auto;
  padding-top: 1.5rem;
  display: flex;
  justify-content: flex-end;
}
.service-arrow {
  color: var(--ember-2);
  transition: transform 0.25s cubic-bezier(0.4, 0, 0.2, 1), color 0.2s;
  display: flex;
}
.service-card:hover .service-arrow { transform: translateX(6px); color: var(--ember-1); }

/* WHY */
.why-section { background: var(--dark-card); border-top: 1px solid var(--dark-border); border-bottom: 1px solid var(--dark-border); }
.why-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 5rem; align-items: center; }
.why-right { display: flex; flex-direction: column; gap: 2.5rem; }
.why-item { display: flex; gap: 1.5rem; align-items: flex-start; }
.why-num {
  font-size: 0.7rem;
  color: var(--ember-2);
  letter-spacing: 0.1em;
  min-width: 28px;
  padding-top: 0.25rem;
  opacity: 0.7;
}
.why-icon-wrap { padding-top: 0.1rem; color: var(--ember-3); flex-shrink: 0; }
.why-content { flex: 1; }

/* CTA BAND */
.cta-band { padding: 5rem 0; }
.cta-inner {
  background: var(--dark-card);
  border: 1px solid var(--dark-border);
  padding: 4rem;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 3rem;
  position: relative;
  overflow: hidden;
  clip-path: polygon(0 0, calc(100% - 24px) 0, 100% 24px, 100% 100%, 24px 100%, 0 calc(100% - 24px));
}
.cta-inner::before {
  content: '';
  position: absolute;
  top: 0; left: 0; right: 0;
  height: 2px;
  background: var(--gradient-fire);
}
.cta-glow {
  position: absolute;
  top: 50%; left: 50%; transform: translate(-50%, -50%);
  width: 600px; height: 200px;
  background: radial-gradient(ellipse, rgba(255,70,0,0.06), transparent 70%);
  pointer-events: none;
}
.cta-actions { display: flex; gap: 1rem; flex-wrap: wrap; flex-shrink: 0; }

@media (max-width: 1024px) {
  .hero-logo-float { display: none; }
}
@media (max-width: 900px) {
  .hero-content { grid-template-columns: 1fr; gap: 3rem; }
}
@media (max-width: 768px) {
  .hero-stats { gap: 1.5rem; flex-wrap: wrap; }
  .services-grid { grid-template-columns: 1fr; }
  .why-grid { grid-template-columns: 1fr; gap: 3rem; }
  .cta-inner { flex-direction: column; }
  .cta-actions { width: 100%; }
}
</style>