---
import BaseLayout from '../layouts/BaseLayout.astro';
import CalendarLight from 'phosphor-astro/CalendarLight.astro';
import StorefrontLight from 'phosphor-astro/StorefrontLight.astro';
import LinkLight from 'phosphor-astro/LinkLight.astro';
import HardDrivesLight from 'phosphor-astro/HardDrivesLight.astro';
import ChartBarLight from 'phosphor-astro/ChartBarLight.astro';
import HardDriveLight from 'phosphor-astro/HardDriveLight.astro';
import ArrowRightLight from 'phosphor-astro/ArrowRightLight.astro';

const projects = [
  {
    icon: CalendarLight,
    category: 'Applications',
    title: 'Event Flow',
    desc: 'Application de billetterie en ligne — création d\'événements, vente de billets, QR codes de validation et gestion des participants.',
    stack: ['React', 'Node.js', 'Stripe', 'PostgreSQL'],
    year: '2025',
    id: 'event-flow',
    photos: [] as string[],
  },
  {
    icon: StorefrontLight,
    category: 'Sites Web',
    title: 'Moment D. Art',
    desc: 'Site vitrine haut de gamme pour Arno Momin, artisan peintre. Peinture intérieure/extérieure, enduits décoratifs, revêtement de sol — galerie de réalisations, 6 pages de services, formulaire de devis.',
    stack: ['Astro', 'CSS', 'Netlify'],
    year: '2025',
    id: 'moment-d-art',
    photos: [
      '/emberfox-site/images/projects/moment-d-art/hero.png',
      '/emberfox-site/images/projects/moment-d-art/apropos.png',
      '/emberfox-site/images/projects/moment-d-art/services.png',
    ],
  },
  {
    icon: LinkLight,
    category: 'Applications',
    title: 'Roue de fortune Twitch',
    desc: 'Mini roue de fortune interactive pour un streamer Twitch — segments personnalisables en direct, animations fluides, prête pour overlay OBS.',
    stack: ['JavaScript', 'Canvas API', 'CSS'],
    year: '2025',
    id: 'roue-fortune',
    photos: [] as string[],
  },
  {
    icon: HardDrivesLight,
    category: 'Montage PC',
    title: 'Build Gaming Full Corsair',
    desc: 'Montage PC gaming haut de gamme — RTX 5080, Ryzen 7 7800X3D, full Corsair. Câblage soigné, éclairage ARGB synchronisé via iCUE.',
    stack: ['RTX 5080', 'Ryzen 7 7800X3D', 'Corsair', 'Windows 11'],
    year: '2025',
    id: 'build-gaming',
    photos: [] as string[],
  },
  {
    icon: ChartBarLight,
    category: 'Applications',
    title: 'Devis & More',
    desc: 'Application de création et gestion de devis pour les professionnels du bâtiment — multi-corps de métier, calcul automatique, export PDF.',
    stack: ['React', 'Node.js', 'PDFKit', 'PostgreSQL'],
    year: '2026',
    id: 'devis-more',
    photos: [] as string[],
  },
  {
    icon: HardDriveLight,
    category: 'Dépannage',
    title: 'Migration PC à domicile',
    desc: 'Accompagnement complet au changement de PC — migration des données, profils utilisateur, logiciels et préférences d\'un ordinateur à l\'autre.',
    stack: ['Windows', 'Backup & Restore', 'Migration'],
    year: '2025',
    id: 'migration-pc',
    photos: [] as string[],
  },
];

const catColor: Record<string, string> = {
  'Applications': 'rgba(255,69,0,0.10)',
  'Sites Web':    'rgba(255,140,0,0.12)',
  'Montage PC':   'rgba(255,184,48,0.10)',
  'Dépannage':    'rgba(255,100,0,0.10)',
};
---
<BaseLayout title="Projets" description="Réalisations et projets — EmberFox">

  <section class="page-hero">
    <div class="container">
      <div class="page-hero-inner">
        <p class="section-pre mono-font fire-text">— Réalisations</p>
        <h1 class="display-font page-title">Mes<br/><span class="fire-text">Projets</span></h1>
        <p class="page-sub">Sites web, applications, PC montés sur mesure, dépannage — chaque projet est une nouvelle occasion de construire quelque chose qui fonctionne vraiment.</p>
        <a href="/emberfox-site/Contact" class="btn-fire">
          Parler de mon projet
          <ArrowRightLight width={16} height={16} />
        </a>
      </div>
    </div>
    <div class="page-deco-bg" aria-hidden="true">
      <svg viewBox="0 0 500 480" fill="none" xmlns="http://www.w3.org/2000/svg">
        <defs>
          <radialGradient id="projGlow" cx="50%" cy="50%" r="55%">
            <stop offset="0%" stop-color="rgba(255,80,0,0.10)"/>
            <stop offset="100%" stop-color="rgba(255,60,0,0)"/>
          </radialGradient>
        </defs>
        <ellipse cx="250" cy="240" rx="220" ry="200" fill="url(#projGlow)"/>
        <g font-family="'Courier New', monospace" font-size="13">
          <text x="30" y="55"  fill="rgba(255,140,0,0.22)">$ ls -la ~/projets/</text>
          <text x="30" y="78"  fill="rgba(255,100,0,0.12)">total 6 projets</text>
          <text x="30" y="112" fill="rgba(255,140,0,0.18)">drwxr--  event-flow/           2025</text>
          <text x="30" y="137" fill="rgba(255,140,0,0.18)">drwxr--  moment-d-art/         2025</text>
          <text x="30" y="162" fill="rgba(255,140,0,0.18)">drwxr--  roue-fortune-twitch/  2025</text>
          <text x="30" y="187" fill="rgba(255,140,0,0.18)">drwxr--  build-gaming-corsair/ 2025</text>
          <text x="30" y="212" fill="rgba(255,140,0,0.18)">drwxr--  devis-and-more/       2026</text>
          <text x="30" y="237" fill="rgba(255,140,0,0.18)">drwxr--  migration-pc/         2025</text>
          <text x="30" y="272" fill="rgba(255,120,0,0.20)">$ git log --oneline</text>
          <text x="30" y="297" fill="rgba(255,100,0,0.16)">a1b2c3d feat: event-flow stripe v2</text>
          <text x="30" y="322" fill="rgba(255,100,0,0.14)">d4e5f6g feat: devis-more pdf export</text>
          <text x="30" y="347" fill="rgba(255,100,0,0.14)">7h8i9j0 feat: twitch wheel segments</text>
          <text x="30" y="372" fill="rgba(255,100,0,0.14)">k1l2m3n fix: moment-d-art mobile</text>
          <text x="30" y="408" fill="rgba(255,80,0,0.12)">$ npm run build</text>
          <text x="30" y="433" fill="rgba(255,140,0,0.22)">  ✓ 6 projets livrés</text>
          <text x="30" y="458" fill="rgba(255,80,0,0.10)">_</text>
        </g>
      </svg>
    </div>
  </section>

  <!-- GRID -->
  <section class="section">
    <div class="container">
      <p class="section-pre mono-font fire-text">— Portfolio</p>
      <h2 class="display-font" style="font-size:clamp(2rem,4vw,3rem);margin-bottom:0.5rem">Ce que j'ai construit</h2>
      <div class="fire-divider"></div>
      <div class="projects-grid">
        {projects.map(p => (
          <div
            class="project-card card"
            role="button"
            tabindex="0"
            aria-label={`Voir le projet ${p.title}`}
            data-id={p.id}
            data-title={p.title}
            data-category={p.category}
            data-year={p.year}
            data-desc={p.desc}
            data-stack={JSON.stringify(p.stack)}
            data-photos={JSON.stringify(p.photos)}
          >
            <div class="project-header" style={`background:${catColor[p.category] ?? 'rgba(255,100,0,0.08)'}`}>
              <p.icon width={28} height={28} class="project-icon" />
              <span class="project-cat mono-font">{p.category}</span>
              <span class="project-year mono-font">{p.year}</span>
            </div>
            <div class="project-body">
              <h3 class="display-font project-title">{p.title}</h3>
              <p class="project-desc">{p.desc}</p>
              <div class="project-tags">
                {p.stack.map(t => <span class="tag">{t}</span>)}
              </div>
              <span class="project-hint mono-font">
                <svg width="12" height="12" viewBox="0 0 12 12" fill="none" aria-hidden="true">
                  <rect x="1" y="1.5" width="10" height="8" rx="1" stroke="currentColor" stroke-width="1.2"/>
                  <circle cx="4" cy="4.5" r="1" stroke="currentColor" stroke-width="1"/>
                  <path d="M1 8l2.5-2.5 2 2 1.5-1.5 3 3" stroke="currentColor" stroke-width="1.1" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
                {p.photos.length > 0 ? 'Voir les photos' : 'Voir les détails'}
              </span>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="section" style="background:var(--dark-card);border-top:1px solid var(--dark-border);border-bottom:1px solid var(--dark-border)">
    <div class="container cta-inner">
      <div>
        <p class="section-pre mono-font fire-text">— Votre tour</p>
        <h2 class="display-font" style="font-size:clamp(2rem,4vw,3rem)">Un projet en tête ?</h2>
        <p style="color:var(--text-secondary);margin-top:0.75rem;max-width:520px;line-height:1.7">Discutons de votre idée. Premier échange gratuit, sans engagement.</p>
      </div>
      <div style="display:flex;gap:1rem;flex-wrap:wrap;align-items:center">
        <a href="/emberfox-site/Contact" class="btn-fire">
          Démarrer un projet
          <ArrowRightLight width={16} height={16} />
        </a>
        <a href="/emberfox-site/A-propos" class="btn-outline">En savoir plus</a>
      </div>
    </div>
  </section>

  <!-- ═══ MODAL ═══ -->
  <dialog class="project-modal" id="projectModal" aria-modal="true" aria-labelledby="modalTitle">
    <div class="modal-inner">

      <!-- Header -->
      <div class="modal-header">
        <div class="modal-meta">
          <p class="modal-cat mono-font fire-text" id="modalCat"></p>
          <h2 class="display-font modal-title" id="modalTitle"></h2>
          <p class="modal-year mono-font" id="modalYear"></p>
        </div>
        <button class="modal-close" id="modalClose" aria-label="Fermer">
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
            <path d="M2 2l12 12M14 2L2 14" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/>
          </svg>
        </button>
      </div>

      <div class="modal-content">
        <!-- Info -->
        <aside class="modal-info">
          <div class="modal-info-head">
            <p class="modal-info-kicker mono-font fire-text">- Pr&eacute;sentation</p>
            <h3 class="display-font modal-info-title">D&eacute;tails du projet</h3>
          </div>
          <p class="modal-desc" id="modalDesc"></p>
          <div class="modal-stack">
            <p class="modal-stack-label mono-font">Stack technique</p>
            <div class="modal-tags" id="modalTags"></div>
          </div>
        </aside>

        <!-- Gallery -->
        <section class="modal-gallery-panel" aria-label="Galerie du projet">
          <div class="modal-gallery" id="modalGallery"></div>
        </section>
      </div>

    </div>
  </dialog>

  <!-- ═══ LIGHTBOX ═══ -->
  <div class="lightbox" id="lightbox" role="dialog" aria-modal="true" hidden>
    <button class="lb-close" id="lbClose" aria-label="Fermer">
      <svg width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true">
        <path d="M3 3l12 12M15 3L3 15" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/>
      </svg>
    </button>
    <button class="lb-nav lb-prev" id="lbPrev" aria-label="Précédent">
      <svg width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true">
        <path d="M12 15l-6-6 6-6" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </button>
    <button class="lb-nav lb-next" id="lbNext" aria-label="Suivant">
      <svg width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true">
        <path d="M6 3l6 6-6 6" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </button>
    <figure class="lb-figure">
      <img class="lb-img" id="lbImg" src="" alt="" />
      <figcaption class="lb-caption mono-font" id="lbCaption"></figcaption>
    </figure>
  </div>

</BaseLayout>

<style>
/* ── Hero deco ── */
.page-deco-bg g > text { animation: proj-in 0.35s ease both; }
.page-deco-bg g > text:nth-child(1)  { animation-delay: 0.20s; }
.page-deco-bg g > text:nth-child(2)  { animation-delay: 0.40s; }
.page-deco-bg g > text:nth-child(3)  { animation-delay: 0.65s; }
.page-deco-bg g > text:nth-child(4)  { animation-delay: 0.82s; }
.page-deco-bg g > text:nth-child(5)  { animation-delay: 0.99s; }
.page-deco-bg g > text:nth-child(6)  { animation-delay: 1.16s; }
.page-deco-bg g > text:nth-child(7)  { animation-delay: 1.33s; }
.page-deco-bg g > text:nth-child(8)  { animation-delay: 1.60s; }
.page-deco-bg g > text:nth-child(9)  { animation-delay: 1.80s; }
.page-deco-bg g > text:nth-child(10) { animation-delay: 2.00s; }
.page-deco-bg g > text:nth-child(11) { animation-delay: 2.18s; }
.page-deco-bg g > text:nth-child(12) { animation-delay: 2.36s; }
.page-deco-bg g > text:nth-child(13) { animation-delay: 2.65s; }
.page-deco-bg g > text:nth-child(14) { animation-delay: 2.85s; }
.page-deco-bg g > text:nth-child(15) { animation-delay: 3.10s; }
@keyframes proj-in { from { opacity: 0; } to { opacity: 1; } }

/* ── Project grid ── */
.projects-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 1.25rem;
  margin-top: 2rem;
}

/* ── Project card ── */
.project-card { padding: 0; overflow: hidden; cursor: pointer; }
.project-header {
  display: flex;
  align-items: center;
  gap: 0.75rem;
  padding: 0.875rem 1.5rem;
  border-bottom: 1px solid var(--dark-border);
}
.project-icon { color: var(--ember-2); opacity: 0.8; flex-shrink: 0; }
.project-cat  { font-size: 0.72rem; letter-spacing: 0.15em; color: var(--ember-3); flex: 1; }
.project-year { font-size: 0.72rem; letter-spacing: 0.10em; color: var(--text-muted); }
.project-body { padding: 1.5rem; display: flex; flex-direction: column; gap: 0.75rem; }
.project-title { font-size: 1.3rem; color: var(--text-primary); line-height: 1.1; }
.project-desc  { color: var(--text-secondary); font-size: 0.875rem; line-height: 1.65; }
.project-tags  { display: flex; flex-wrap: wrap; gap: 0.4rem; }
.tag {
  padding: 0.2rem 0.6rem;
  background: var(--dark-card-2);
  border: 1px solid var(--dark-border);
  color: var(--text-muted);
  font-family: 'JetBrains Mono', monospace;
  font-size: 0.7rem;
  letter-spacing: 0.05em;
}
.project-hint {
  display: inline-flex;
  align-items: center;
  gap: 0.35rem;
  color: var(--text-muted);
  font-size: 0.72rem;
  letter-spacing: 0.1em;
  opacity: 0;
  transform: translateY(4px);
  transition: opacity 0.2s, transform 0.2s, color 0.2s;
}
.project-card:hover .project-hint { opacity: 1; transform: translateY(0); color: var(--ember-3); }

/* ── CTA row ── */
.cta-inner { display: flex; align-items: center; justify-content: space-between; gap: 2rem; flex-wrap: wrap; }

/* ══════════════════════════════════
   MODAL — centré, flou backdrop
══════════════════════════════════ */
.project-modal {
  /* Force centering — overrides UA default top-left */
  position: fixed;
  inset: 0;
  margin: auto;
  width: min(1120px, calc(100vw - 3rem));
  max-width: none;
  height: fit-content;
  max-height: calc(100dvh - 3rem);
  padding: 0;
  background: var(--dark-card);
  border: 1px solid var(--dark-border-2);
  color: var(--text-primary);
  clip-path: polygon(0 0, calc(100% - 16px) 0, 100% 16px, 100% 100%, 16px 100%, 0 calc(100% - 16px));
  overflow: hidden;
  box-shadow: 0 28px 90px rgba(0,0,0,0.72), 0 0 80px rgba(255,69,0,0.08);
}
.project-modal::backdrop {
  background: rgba(4, 3, 2, 0.86);
  backdrop-filter: blur(14px);
}

.modal-inner {
  display: block;
  overflow-y: auto;
  overflow-x: hidden;
  max-height: calc(100dvh - 3rem);
  overscroll-behavior: contain;
}

/* ─── Header ─── */
.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 1rem;
  padding: clamp(1.35rem, 2.4vw, 2.1rem) clamp(1.25rem, 3vw, 2.4rem) 0.85rem;
  border-bottom: 0;
  background:
    radial-gradient(circle at 8% 0%, rgba(255,140,0,0.10), transparent 30%),
    var(--dark-card);
  position: relative;
  z-index: 3;
}
.modal-meta { display: flex; flex-direction: column; gap: 0.45rem; min-width: 0; max-width: 720px; }
.modal-cat {
  align-self: flex-start;
  padding: 0.23rem 0.65rem;
  background: rgba(255,140,0,0.10);
  border: 1px solid rgba(255,140,0,0.18);
  font-size: 0.62rem;
  letter-spacing: 0.16em;
  text-transform: uppercase;
}
.modal-title { font-size: clamp(1.85rem, 3.4vw, 3rem); line-height: 0.95; overflow-wrap: anywhere; }
.modal-year  { font-size: 0.68rem; color: var(--text-muted); letter-spacing: 0.12em; }

.modal-close {
  flex-shrink: 0;
  background: rgba(255,255,255,0.02);
  border: 1px solid rgba(255,140,0,0.18);
  color: var(--text-muted);
  cursor: pointer;
  min-height: unset;
  width: 42px;
  height: 42px;
  display: flex;
  align-items: center;
  justify-content: center;
  clip-path: polygon(0 0, calc(100% - 7px) 0, 100% 7px, 100% 100%, 7px 100%, 0 calc(100% - 7px));
  transition: border-color 0.2s, color 0.2s, background 0.2s;
}
.modal-close:hover { border-color: var(--ember-2); color: var(--ember-3); background: rgba(255,69,0,0.08); }

.modal-content {
  display: flex;
  flex-direction: column;
  min-width: 0;
}

.modal-gallery-panel {
  min-width: 0;
  background:
    linear-gradient(180deg, rgba(255,255,255,0.018), transparent 18%),
    #070503;
  border-top: 1px solid var(--dark-border);
}

.modal-gallery {
  min-width: 0;
  max-width: 1040px;
  margin: 0 auto;
  padding: clamp(1rem, 2.2vw, 1.6rem);
}

.modal-info {
  min-width: 0;
  max-width: 720px;
  padding: 0 clamp(1.25rem, 3vw, 2.4rem) clamp(1.35rem, 2.5vw, 2rem);
  display: flex;
  flex-direction: column;
  gap: 0.9rem;
  background: var(--dark-card);
}
.modal-info-head {
  display: none;
}
.modal-info-kicker {
  font-size: 0.68rem;
  letter-spacing: 0.18em;
}
.modal-info-title {
  color: var(--text-primary);
  font-size: clamp(1.45rem, 2vw, 2rem);
  line-height: 1;
}
.modal-desc {
  color: var(--text-secondary);
  font-size: 0.95rem;
  line-height: 1.75;
  max-width: 680px;
}
.modal-stack {
  display: flex;
  flex-direction: column;
  gap: 0.5rem;
}
.modal-stack-label {
  color: var(--text-muted);
  font-size: 0.68rem;
  letter-spacing: 0.14em;
  text-transform: uppercase;
}
.modal-tags { display: flex; flex-wrap: wrap; gap: 0.42rem; }
.modal-tags .tag { max-width: 100%; overflow-wrap: anywhere; }

/* ══════════════════════════════════
   GALLERY VIEWER
══════════════════════════════════ */

/* Image stage — hauteur fixe, l'image se contient dedans */
.gallery-stage {
  width: 100%;
  height: clamp(420px, 58vh, 680px);
  overflow-x: hidden;
  overflow-y: auto;
  background:
    linear-gradient(135deg, rgba(255,255,255,0.035), transparent 34%),
    #050302;
  display: block;
  padding: clamp(0.75rem, 1.4vw, 1.25rem);
  scrollbar-width: thin;
  scrollbar-color: rgba(255,140,0,0.55) rgba(255,255,255,0.04);
}
.gallery-img {
  width: 100%;
  max-width: 100%;
  height: auto;
  object-fit: contain;
  object-position: top center;
  display: block;
  margin: 0 auto;
  box-shadow: 0 16px 42px rgba(0,0,0,0.45);
  transition: opacity 0.14s ease;
}
.gallery-img.fading { opacity: 0; }
.gallery-stage::-webkit-scrollbar { width: 5px; }
.gallery-stage::-webkit-scrollbar-track { background: rgba(255,255,255,0.04); }
.gallery-stage::-webkit-scrollbar-thumb { background: rgba(255,140,0,0.55); border-radius: 999px; }

/* Barre de contrôles */
.gallery-bar {
  display: flex;
  align-items: stretch;
  min-height: 48px;
  border-top: 1px solid var(--dark-border);
  background: rgba(16, 11, 6, 0.92);
}
.g-nav {
  width: 52px;
  flex-shrink: 0;
  background: transparent;
  border: none;
  border-right: 1px solid var(--dark-border);
  color: var(--text-muted);
  cursor: pointer;
  min-height: unset;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: color 0.2s;
}
.g-nav:last-child { border-right: none; border-left: 1px solid var(--dark-border); }
.g-nav:hover  { color: var(--ember-3); }
.g-nav:disabled { opacity: 0.2; pointer-events: none; }
.g-count {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  font-family: 'JetBrains Mono', monospace;
  font-size: 0.72rem;
  color: var(--text-muted);
  letter-spacing: 0.12em;
  border-right: 1px solid var(--dark-border);
}
.g-fs {
  width: 52px;
  flex-shrink: 0;
  background: transparent;
  border: none;
  border-right: 1px solid var(--dark-border);
  color: var(--text-muted);
  cursor: pointer;
  min-height: unset;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: color 0.2s;
}
.g-fs:hover { color: var(--ember-3); }

/* Miniatures — flex-wrap, zéro scroll */
.gallery-thumbs {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(92px, 1fr));
  gap: 0.55rem;
  padding: 0.85rem clamp(0.85rem, 1.4vw, 1.25rem);
  border-top: 1px solid var(--dark-border);
  background: rgba(16, 11, 6, 0.92);
  overflow-x: hidden;
}
.g-thumb {
  width: 100%;
  aspect-ratio: 16 / 10;
  height: auto;
  overflow: hidden;
  border: 2px solid var(--dark-border);
  background: var(--dark-bg);
  cursor: pointer;
  padding: 0;
  min-height: unset;
  transition: border-color 0.15s;
}
.g-thumb img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  object-position: top center;
  display: block;
  transition: transform 0.2s ease;
}
.g-thumb:hover            { border-color: rgba(255,140,0,0.5); }
.g-thumb:hover img        { transform: scale(1.08); }
.g-thumb.active           { border-color: var(--ember-2); }

/* Galerie projet continue */
.project-gallery-grid {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  grid-auto-rows: 12px;
  grid-auto-flow: dense;
  gap: clamp(0.8rem, 1.5vw, 1.1rem);
}
.gallery-shot {
  display: block;
  width: 100%;
  height: 100%;
  grid-row: span 18;
  margin: 0;
  padding: 0;
  min-height: unset;
  overflow: hidden;
  background: #050302;
  border: 1px solid var(--dark-border);
  cursor: pointer;
  clip-path: polygon(0 0, calc(100% - 12px) 0, 100% 12px, 100% 100%, 12px 100%, 0 calc(100% - 12px));
  box-shadow: 0 14px 34px rgba(0,0,0,0.34);
  transition: border-color 0.2s, transform 0.2s, box-shadow 0.2s;
}
.gallery-shot:nth-child(3n + 1) { grid-row: span 24; }
.gallery-shot:nth-child(3n + 3) { grid-row: span 22; }
.gallery-shot:hover {
  border-color: rgba(255,140,0,0.46);
  transform: translateY(-1px);
  box-shadow: 0 18px 42px rgba(0,0,0,0.46), 0 0 26px rgba(255,69,0,0.06);
}
.gallery-shot img {
  width: 100%;
  height: 100%;
  display: block;
  object-fit: cover;
  object-position: top center;
  transition: transform 0.35s ease, filter 0.2s ease;
}
.gallery-shot:hover img {
  transform: scale(1.015);
  filter: brightness(1.06);
}

/* Pas de photos */
.gallery-empty {
  min-height: clamp(360px, 52vh, 620px);
  padding: 2rem;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-direction: column;
  gap: 0.75rem;
  color: var(--text-muted);
  font-family: 'JetBrains Mono', monospace;
  font-size: 0.74rem;
  letter-spacing: 0.1em;
  text-align: center;
}

/* ══════════════════════════════════
   LIGHTBOX
══════════════════════════════════ */
.lightbox {
  position: fixed;
  inset: 0;
  background: rgba(4,3,2,0.96);
  backdrop-filter: blur(10px);
  z-index: 9997;
  display: flex;
  align-items: center;
  justify-content: center;
}
.lightbox[hidden] { display: none; }

.lb-close {
  position: absolute;
  top: 1rem;
  right: 1rem;
  background: rgba(255,255,255,0.04);
  border: 1px solid rgba(255,255,255,0.10);
  color: var(--text-primary);
  cursor: pointer;
  min-height: unset;
  width: 40px;
  height: 40px;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: background 0.2s, border-color 0.2s;
}
.lb-close:hover { background: rgba(255,69,0,0.2); border-color: var(--ember-2); }

.lb-nav {
  position: absolute;
  top: 50%;
  transform: translateY(-50%);
  background: rgba(255,255,255,0.04);
  border: 1px solid rgba(255,255,255,0.10);
  color: var(--text-primary);
  cursor: pointer;
  min-height: unset;
  width: 46px;
  height: 46px;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: background 0.2s, border-color 0.2s;
}
.lb-nav:hover { background: rgba(255,69,0,0.2); border-color: var(--ember-2); }
.lb-nav:disabled { opacity: 0.18; pointer-events: none; }
.lb-prev { left: 1rem; }
.lb-next { right: 1rem; }

.lb-figure {
  margin: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 0.75rem;
  max-width: calc(100vw - 8rem);
  max-height: calc(100vh - 4rem);
  padding: 0 3.5rem;
}
.lb-img {
  display: block;
  max-width: 100%;
  max-height: calc(100vh - 6rem);
  width: auto;
  height: auto;
  box-shadow: 0 8px 48px rgba(0,0,0,0.6);
  transition: opacity 0.15s ease;
}
.lb-img.lb-fade { opacity: 0; }
.lb-caption {
  font-size: 0.7rem;
  color: rgba(255,255,255,0.3);
  letter-spacing: 0.12em;
}

/* ── Responsive ── */
@media (max-width: 1024px) {
  .projects-grid { grid-template-columns: repeat(2, 1fr); }
}
@media (max-width: 768px) {
  .project-modal {
    width: calc(100vw - 1rem);
    max-height: calc(100dvh - 1rem);
  }
  .modal-inner { max-height: calc(100dvh - 1rem); }
  .modal-gallery { padding: 1rem; }
  .project-gallery-grid { grid-template-columns: repeat(2, minmax(0, 1fr)); }
  .gallery-shot { grid-row: span 16; }
  .gallery-shot:nth-child(3n + 1),
  .gallery-shot:nth-child(3n + 3) { grid-row: span 20; }
  .lb-prev { left: 0.4rem; }
  .lb-next { right: 0.4rem; }
  .lb-figure { max-width: calc(100vw - 5rem); padding: 0 2.5rem; }
}
@media (max-width: 480px) {
  .projects-grid { grid-template-columns: 1fr; }
  .project-modal { width: calc(100vw - 0.5rem); }
  .modal-header  { padding: 0.9rem 0.9rem 0.8rem; }
  .modal-title   { font-size: clamp(1.35rem, 8vw, 1.9rem); }
  .modal-close   { width: 38px; height: 38px; }
  .modal-info    { padding: 1rem; }
  .modal-gallery { padding: 0.75rem; }
  .project-gallery-grid { grid-template-columns: 1fr; grid-auto-rows: 10px; }
  .gallery-shot,
  .gallery-shot:nth-child(3n + 1),
  .gallery-shot:nth-child(3n + 3) { grid-row: span 24; }
  .cta-inner     { flex-direction: column; align-items: flex-start; }
  .lb-figure     { max-width: 100vw; padding: 0 2.25rem; }
  .lb-prev       { left: 0.2rem; }
  .lb-next       { right: 0.2rem; }
  .lb-img        { max-height: calc(100vh - 5rem); }
}
@media (hover: none) {
  .project-hint { opacity: 1 !important; transform: none !important; color: var(--ember-3) !important; }
}
</style>

<script>
const modal    = document.getElementById('projectModal') as HTMLDialogElement | null;
const mTitle   = document.getElementById('modalTitle');
const mCat     = document.getElementById('modalCat');
const mYear    = document.getElementById('modalYear');
const mGallery = document.getElementById('modalGallery');
const mDesc    = document.getElementById('modalDesc');
const mTags    = document.getElementById('modalTags');
const mClose   = document.getElementById('modalClose');

const lb       = document.getElementById('lightbox');
const lbImg    = document.getElementById('lbImg')  as HTMLImageElement | null;
const lbCap    = document.getElementById('lbCaption');
const lbClose  = document.getElementById('lbClose');
const lbPrev   = document.getElementById('lbPrev') as HTMLButtonElement | null;
const lbNext   = document.getElementById('lbNext') as HTMLButtonElement | null;

let photos: string[] = [];
let lbIdx  = 0;
let galIdx = 0;

// Open modal on card click
document.querySelectorAll<HTMLElement>('.project-card').forEach(card => {
  card.addEventListener('click', () => openModal(card));
  card.addEventListener('keydown', e => {
    if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); openModal(card); }
  });
});

function openModal(el: HTMLElement) {
  photos = JSON.parse(el.dataset.photos ?? '[]');
  galIdx = 0;
  if (mTitle) mTitle.textContent = el.dataset.title    ?? '';
  if (mCat)   mCat.textContent   = `— ${el.dataset.category ?? ''}`;
  if (mYear)  mYear.textContent  = el.dataset.year     ?? '';
  if (mDesc)  mDesc.textContent  = el.dataset.desc     ?? '';
  if (mTags)  mTags.innerHTML    = JSON.parse(el.dataset.stack ?? '[]')
    .map((t: string) => `<span class="tag">${t}</span>`).join('');
  buildStackedGallery();
  modal?.showModal();
  (modal?.querySelector('.modal-inner') as HTMLElement | null)?.scrollTo({ top: 0, left: 0 });
}

function buildStackedGallery() {
  if (!mGallery) return;

  if (photos.length === 0) {
    mGallery.innerHTML = `
      <div class="gallery-empty">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" opacity="0.45">
          <rect x="1" y="3" width="22" height="18" rx="2" stroke="currentColor" stroke-width="1.2"/>
          <circle cx="8" cy="9" r="2" stroke="currentColor" stroke-width="1.2"/>
          <path d="M1 18.5l5.5-5.5 3.5 3.5 3-3 7 7" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
        <span>Photos &agrave; venir</span>
      </div>`;
    return;
  }

  mGallery.innerHTML = `
    <div class="project-gallery-grid">
      ${photos.map((src, i) => `
        <button class="gallery-shot" data-i="${i}" aria-label="Agrandir la photo ${i + 1}">
          <img src="${src}" alt="Photo ${i + 1}" loading="${i === 0 ? 'eager' : 'lazy'}" draggable="false" />
        </button>`).join('')}
    </div>
  `;

  mGallery.querySelectorAll<HTMLElement>('.gallery-shot').forEach(b =>
    b.addEventListener('click', () => openLb(parseInt(b.dataset.i ?? '0')))
  );
}

function buildGallery() {
  if (!mGallery) return;

  if (photos.length === 0) {
    mGallery.innerHTML = `
      <div class="gallery-empty">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" opacity="0.45">
          <rect x="1" y="3" width="22" height="18" rx="2" stroke="currentColor" stroke-width="1.2"/>
          <circle cx="8" cy="9" r="2" stroke="currentColor" stroke-width="1.2"/>
          <path d="M1 18.5l5.5-5.5 3.5 3.5 3-3 7 7" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
        <span>Photos à venir</span>
      </div>`;
    return;
  }

  const multi = photos.length > 1;
  const navIcon = (dir: 'l'|'r') =>
    `<svg width="13" height="13" viewBox="0 0 13 13" fill="none">
      <path d="${dir==='l'?'M9 10L5 6.5l4-3.5':'M4 3l4 3.5-4 3.5'}" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
    </svg>`;
  const expandIcon =
    `<svg width="11" height="11" viewBox="0 0 11 11" fill="none">
      <path d="M1 3.5V1h2.5M7.5 1H10v2.5M10 7.5V10H7.5M3.5 10H1V7.5" stroke="currentColor" stroke-width="1.35" stroke-linecap="round" stroke-linejoin="round"/>
    </svg>`;

  mGallery.innerHTML = `
    <div class="gallery-stage">
      <img class="gallery-img" id="gImg" src="${photos[0]}" alt="Photo 1" draggable="false" />
    </div>
    <div class="gallery-bar">
      ${multi ? `<button class="g-nav" id="gPrev" aria-label="Précédent" disabled>${navIcon('l')}</button>` : ''}
      <div class="g-count mono-font" id="gCounter">${multi ? `1 / ${photos.length}` : '1 photo'}</div>
      <button class="g-fs" id="gExpand" aria-label="Plein écran">${expandIcon}</button>
      ${multi ? `<button class="g-nav" id="gNext" aria-label="Suivant">${navIcon('r')}</button>` : ''}
    </div>
    ${multi ? `
    <div class="gallery-thumbs" id="gThumbs">
      ${photos.map((src, i) => `
        <button class="g-thumb${i === 0 ? ' active' : ''}" data-i="${i}" aria-label="Photo ${i + 1}">
          <img src="${src}" alt="" loading="lazy" />
        </button>`).join('')}
    </div>` : ''}
  `;

  const img      = mGallery.querySelector<HTMLImageElement>('#gImg');
  const counter  = mGallery.querySelector<HTMLElement>('#gCounter');
  const prevBtn  = mGallery.querySelector<HTMLButtonElement>('#gPrev');
  const nextBtn  = mGallery.querySelector<HTMLButtonElement>('#gNext');
  const expandBtn = mGallery.querySelector<HTMLButtonElement>('#gExpand');
  const thumbs   = mGallery.querySelector<HTMLElement>('#gThumbs');
  const stage = mGallery.querySelector<HTMLElement>('.gallery-stage');

  function goTo(i: number) {
    galIdx = i;
    stage?.scrollTo({ top: 0, left: 0 });
    if (img) {
      img.classList.add('fading');
      setTimeout(() => {
        img.src = photos[i];
        img.alt = `Photo ${i + 1}`;
        img.classList.remove('fading');
      }, 130);
    }
    if (counter && multi) counter.textContent = `${i + 1} / ${photos.length}`;
    if (prevBtn) prevBtn.disabled = i === 0;
    if (nextBtn) nextBtn.disabled = i === photos.length - 1;
    thumbs?.querySelectorAll<HTMLElement>('.g-thumb').forEach((t, ti) =>
      t.classList.toggle('active', ti === i)
    );
  }

  prevBtn?.addEventListener('click', () => { if (galIdx > 0) goTo(galIdx - 1); });
  nextBtn?.addEventListener('click', () => { if (galIdx < photos.length - 1) goTo(galIdx + 1); });
  expandBtn?.addEventListener('click', () => openLb(galIdx));

  thumbs?.querySelectorAll<HTMLElement>('.g-thumb').forEach(b =>
    b.addEventListener('click', () => goTo(parseInt(b.dataset.i ?? '0')))
  );

  // Swipe on stage
  let tx = 0;
  stage?.addEventListener('touchstart', e => { tx = e.touches[0].clientX; }, { passive: true });
  stage?.addEventListener('touchend', e => {
    const dx = e.changedTouches[0].clientX - tx;
    if (Math.abs(dx) < 40) return;
    if (dx < 0 && galIdx < photos.length - 1) goTo(galIdx + 1);
    if (dx > 0 && galIdx > 0) goTo(galIdx - 1);
  }, { passive: true });
}

mClose?.addEventListener('click', () => modal?.close());
modal?.addEventListener('click', e => { if (e.target === modal) modal.close(); });

// ── Lightbox ──
function openLb(i: number) { lbIdx = i; syncLb(); if (lb) lb.hidden = false; }
function closeLb() { if (lb) lb.hidden = true; }

function syncLb() {
  if (lbImg) {
    lbImg.classList.add('lb-fade');
    setTimeout(() => {
      lbImg.src = photos[lbIdx];
      lbImg.alt = `Photo ${lbIdx + 1}`;
      lbImg.classList.remove('lb-fade');
    }, 120);
  }
  if (lbCap) lbCap.textContent = photos.length > 1 ? `${lbIdx + 1} / ${photos.length}` : '';
  if (lbPrev) lbPrev.disabled = lbIdx === 0;
  if (lbNext) lbNext.disabled = lbIdx === photos.length - 1;
}

lbClose?.addEventListener('click', closeLb);
lbPrev?.addEventListener('click',  () => { if (lbIdx > 0) { lbIdx--; syncLb(); } });
lbNext?.addEventListener('click',  () => { if (lbIdx < photos.length - 1) { lbIdx++; syncLb(); } });
lb?.addEventListener('click', e => { if (e.target === lb) closeLb(); });

document.addEventListener('keydown', e => {
  if (!lb || lb.hidden) return;
  if (e.key === 'Escape')     closeLb();
  if (e.key === 'ArrowLeft')  { if (lbIdx > 0) { lbIdx--; syncLb(); } }
  if (e.key === 'ArrowRight') { if (lbIdx < photos.length - 1) { lbIdx++; syncLb(); } }
});

// Swipe lightbox
let touchStartX = 0;
lb?.addEventListener('touchstart', e => { touchStartX = e.touches[0].clientX; }, { passive: true });
lb?.addEventListener('touchend', e => {
  const dx = e.changedTouches[0].clientX - touchStartX;
  if (Math.abs(dx) < 40) return;
  if (dx < 0 && lbIdx < photos.length - 1) { lbIdx++; syncLb(); }
  if (dx > 0 && lbIdx > 0) { lbIdx--; syncLb(); }
}, { passive: true });
</script>
