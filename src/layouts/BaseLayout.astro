---
import '../styles/global.css';
import { Image } from 'astro:assets';
import logo from '../images/logo2.png';
import EnvelopeLight from 'phosphor-astro/EnvelopeLight.astro';
import PhoneLight from 'phosphor-astro/PhoneLight.astro';

const { title = 'EmberFox', description = 'Solutions informatiques sur mesure' } = Astro.props;

const navLinks = [
  { href: '/emberfox-site', label: 'Accueil' },
  { href: '/emberfox-site/A-propos', label: 'À propos' },
  { href: '/emberfox-site/Projets', label: 'Projets' },
  { href: '/emberfox-site/Sites-web', label: 'Sites Web' },
  { href: '/emberfox-site/Applications', label: 'Applications' },
  { href: '/emberfox-site/Montage-pc', label: 'Montage PC' },
  { href: '/emberfox-site/Depannage', label: 'Dépannage' },
  { href: '/emberfox-site/Contact', label: 'Contact' },
];

const currentPath = Astro.url.pathname;
---
<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title} | EmberFox</title>
  <meta name="description" content={description} />
  <link rel="icon" type="image/png" href="/logo.png" />
  <!-- Open Graph -->
  <meta property="og:type" content="website" />
  <meta property="og:site_name" content="EmberFox" />
  <meta property="og:title" content={`${title} | EmberFox`} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={Astro.url.href} />
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={`${title} | EmberFox`} />
  <meta name="twitter:description" content={description} />
</head>
<body>

  <!-- SKIP LINK (accessibility keyboard nav) -->
  <a href="#main-content" class="skip-link">Aller au contenu principal</a>

  <!-- CURSOR GLOW -->
  <div class="cursor-glow" id="cursorGlow" aria-hidden="true"></div>

  <!-- NAV -->
  <nav class="nav" id="nav" aria-label="Navigation principale">
    <div class="nav-inner container">
      <a href="/emberfox-site" class="nav-logo">
        <Image src={logo} alt="EmberFox" width={36} height={45} class="nav-logo-img" format="png" />
        <span class="nav-logo-text"><span class="fire-text">EMBER</span>FOX</span>
      </a>

      <button
        class="nav-toggle"
        id="navToggle"
        aria-label="Ouvrir le menu de navigation"
        aria-expanded="false"
        aria-controls="navLinks"
      >
        <span></span><span></span><span></span>
      </button>

      <ul class="nav-links" id="navLinks" role="list">
        {navLinks.map(link => (
          <li>
            <a
              href={link.href}
              class={`nav-link ${currentPath === link.href ? 'active' : ''}`}
            >
              {link.label}
            </a>
          </li>
        ))}
        <li><a href={import.meta.env.BASE_URL + 'Contact'} class="btn-fire nav-cta">Devis gratuit</a></li>
      </ul>
    </div>
  </nav>

  <main id="main-content">
    <slot />
  </main>

  <!-- FOOTER -->
  <footer class="footer">
    <div class="footer-ember-line"></div>
    <div class="container">
      <div class="footer-grid">
        <div class="footer-brand">
          <div class="footer-logo-wrap">
            <Image src={logo} alt="EmberFox" width={45} height={54} class="footer-logo-img" format="png" />
            <span class="footer-brand-name display-font"><span class="fire-text">EMBER</span>FOX</span>
          </div>
          <p class="footer-tagline">Solutions informatiques<br/>sur mesure — Belgique</p>
          <div class="footer-socials">
            <a href="mailto:contact@emberfox.be" class="social-link" title="Email">
              <EnvelopeLight width={18} height={18} />
            </a>
            <a href="tel:+32498377455" class="social-link" title="Téléphone">
              <PhoneLight width={18} height={18} />
            </a>
          </div>
          <p class="footer-legal mono-font">© 2026 EmberFox</p>
        </div>
        <div class="footer-col">
          <p class="footer-heading display-font">Services</p>
          <ul>
            <li><a href="/emberfox-site/Sites-web">Sites Web</a></li>
            <li><a href="/emberfox-site/Applications">Applications</a></li>
            <li><a href="/emberfox-site/Montage-pc">Montage PC</a></li>
            <li><a href="/emberfox-site/Depannage">Dépannage</a></li>
            <li><a href="/emberfox-site/Projets">Projets</a></li>
          </ul>
        </div>
        <div class="footer-col">
          <p class="footer-heading display-font">Contact</p>
          <ul>
            <li><a href="mailto:contact@emberfox.be">contact@emberfox.be</a></li>
            <li><a href="tel:+32498377455">+32 498 37 74 55</a></li>
            <li><span style="color:var(--text-muted)">Namur, Belgique</span></li>
            <li><span style="color:var(--text-muted)">Lun–Sam · 9h–19h</span></li>
          </ul>
        </div>
      </div>
      <div class="footer-bottom">
        <span class="mono-font" style="color:var(--text-muted);font-size:0.75rem">Conçu avec feu & passion — <span class="fire-text">EmberFox</span></span>
        <div class="footer-bottom-links">
          <a href="/emberfox-site/A-propos" class="mono-font" style="color:var(--text-muted);font-size:0.75rem;text-decoration:none;transition:color 0.2s">À propos</a>
          <a href="/emberfox-site/FAQ" class="mono-font" style="color:var(--text-muted);font-size:0.75rem;text-decoration:none;transition:color 0.2s">FAQ</a>
          <a href="/emberfox-site/Mentions-legales" class="mono-font" style="color:var(--text-muted);font-size:0.75rem;text-decoration:none;transition:color 0.2s">Mentions légales</a>
        </div>
      </div>
    </div>
  </footer>

</body>
</html>

<style>
/* SKIP LINK */
.skip-link {
  position: absolute;
  top: -100%;
  left: 1rem;
  padding: 0.75rem 1.5rem;
  background: var(--ember-1);
  color: #0A0804;
  font-family: 'Bebas Neue', sans-serif;
  font-size: 1rem;
  letter-spacing: 0.1em;
  text-decoration: none;
  z-index: 9999;
  transition: top 0.2s;
}
.skip-link:focus { top: 1rem; }

/* CURSOR GLOW */
.cursor-glow {
  position: fixed;
  width: 300px;
  height: 300px;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(255, 80, 0, 0.06) 0%, transparent 70%);
  pointer-events: none;
  z-index: 9998;
  transform: translate(-50%, -50%);
  transition: opacity 0.3s;
  opacity: 0;
}

/* NAV */
.nav {
  position: fixed;
  top: 0; left: 0; right: 0;
  z-index: 100;
  padding: 1.25rem 0;
  transition: background 0.4s, backdrop-filter 0.4s, padding 0.3s, border-color 0.4s;
  border-bottom: 1px solid transparent;
}
.nav.scrolled {
  background: rgba(10, 8, 4, 0.88);
  backdrop-filter: blur(20px) saturate(180%);
  border-bottom-color: var(--dark-border);
  padding: 0.875rem 0;
}
.nav-inner {
  display: flex;
  align-items: center;
  justify-content: space-between;
  max-width: 1600px;
  padding-left: 3rem;
  padding-right: 3rem;
}
.nav-logo {
  display: flex;
  align-items: center;
  gap: 0.75rem;
  text-decoration: none;
}
.nav-logo-img {
  filter: drop-shadow(0 0 8px rgba(255, 100, 0, 0.45));
  transition: filter 0.3s ease, transform 0.4s ease;
}
.nav-logo:hover .nav-logo-img {
  filter: drop-shadow(0 0 18px rgba(255, 130, 0, 0.9));
  transform: scale(1.1) rotate(-4deg);
}
.nav-logo-text {
  font-family: 'Bebas Neue', sans-serif;
  font-size: 1.7rem;
  letter-spacing: 0.1em;
  color: var(--text-primary);
}
.nav-links {
  display: flex;
  align-items: center;
  gap: 0.1rem;
  list-style: none;
  flex-wrap: nowrap;
}
.nav-link {
  padding: 0.5rem 0.75rem;
  color: var(--text-secondary);
  text-decoration: none;
  font-size: 1rem;
  white-space: nowrap;
  font-weight: 500;
  letter-spacing: 0.05em;
  transition: color 0.2s;
  position: relative;
}
.nav-link::after {
  content: '';
  position: absolute;
  bottom: 0; left: 0.875rem; right: 0.875rem;
  height: 1px;
  background: var(--gradient-fire);
  transform: scaleX(0);
  transition: transform 0.25s cubic-bezier(0.4, 0, 0.2, 1);
  transform-origin: left;
}
.nav-link:hover, .nav-link.active { color: var(--text-primary); }
.nav-link:hover::after, .nav-link.active::after { transform: scaleX(1); }
.nav-cta { font-size: 1rem; padding: 0.65rem 1.4rem; margin-left: 0.5rem; }
.nav-toggle { display: none; }

/* FOOTER */
.footer {
  border-top: 1px solid var(--dark-border);
  padding: 4rem 0 2rem;
  margin-top: 4rem;
  position: relative;
  overflow: hidden;
}
.footer-ember-line {
  position: absolute;
  top: 0; left: 0; right: 0;
  height: 1px;
  background: var(--gradient-fire);
  opacity: 0.4;
}
.footer::after {
  content: '';
  position: absolute;
  bottom: -100px; left: 50%; transform: translateX(-50%);
  width: 800px; height: 300px;
  background: radial-gradient(ellipse, rgba(255, 100, 0, 0.04), transparent 70%);
  pointer-events: none;
}
.footer-grid {
  display: grid;
  grid-template-columns: 2fr 1fr 1fr;
  gap: 3rem;
  margin-bottom: 3rem;
}
.footer-brand { display: flex; flex-direction: column; gap: 1rem; }
.footer-logo-wrap {
  display: flex;
  align-items: center;
  gap: 0.875rem;
}
.footer-logo-img {
  filter: drop-shadow(0 0 10px rgba(255, 100, 0, 0.5));
  transition: filter 0.3s ease, transform 0.3s ease;
}
.footer-logo-wrap:hover .footer-logo-img {
  filter: drop-shadow(0 0 22px rgba(255, 130, 0, 0.85));
  transform: scale(1.05) rotate(-3deg);
}
.footer-brand-name {
  font-size: 1.6rem;
  letter-spacing: 0.1em;
  color: var(--text-primary);
}
.footer-tagline { color: var(--text-secondary); line-height: 1.6; font-size: 0.9rem; }
.footer-legal { color: var(--text-muted); font-size: 0.75rem; margin-top: 0.5rem; }
.footer-socials { display: flex; gap: 0.75rem; }
.social-link {
  display: flex; align-items: center; justify-content: center;
  width: 36px; height: 36px;
  border: 1px solid var(--dark-border);
  color: var(--text-muted);
  text-decoration: none;
  transition: border-color 0.2s, color 0.2s, background 0.2s;
  clip-path: polygon(0 0, calc(100% - 6px) 0, 100% 6px, 100% 100%, 6px 100%, 0 calc(100% - 6px));
}
.social-link:hover { border-color: var(--ember-2); color: var(--ember-3); background: rgba(255,140,0,0.06); }
.footer-heading { font-size: 1.1rem; color: var(--ember-3); margin-bottom: 1rem; }
.footer-col ul { list-style: none; display: flex; flex-direction: column; gap: 0.75rem; }
.footer-col ul li a {
  color: var(--text-secondary);
  text-decoration: none;
  font-size: 0.875rem;
  transition: color 0.2s, padding-left 0.2s;
  display: inline-block;
}
.footer-col ul li a:hover { color: var(--ember-3); padding-left: 4px; }
.footer-bottom {
  border-top: 1px solid var(--dark-border);
  padding-top: 1.5rem;
  display: flex;
  justify-content: space-between;
  align-items: center;
}
.footer-bottom-links { display: flex; gap: 1.5rem; }
.footer-bottom-links a:hover { color: var(--ember-3) !important; }

/* ≤ 1024px — menu burger */
@media (max-width: 1200px) {
  .nav-links {
    display: flex;
    flex-direction: column;
    position: absolute;
    top: 100%; left: 0; right: 0;
    background: rgba(10, 8, 4, 0.97);
    padding: 1rem 1.5rem 1.5rem;
    gap: 0;
    border-bottom: 1px solid var(--dark-border);
    backdrop-filter: blur(20px) saturate(180%);
    z-index: 99;
    opacity: 0;
    visibility: hidden;
    transform: translateY(-10px);
    transition: opacity 0.22s ease, transform 0.22s ease, visibility 0s 0.22s;
  }
  .nav-links.open {
    opacity: 1;
    visibility: visible;
    transform: translateY(0);
    transition: opacity 0.22s ease, transform 0.22s ease, visibility 0s 0s;
  }
  .nav-links li {
    border-bottom: 1px solid var(--dark-border);
    opacity: 0;
    transform: translateX(-8px);
    transition: opacity 0.18s ease, transform 0.18s ease;
  }
  .nav-links li:last-child { border-bottom: none; padding-top: 1rem; }
  .nav-links.open li { opacity: 1; transform: translateX(0); }
  .nav-links.open li:nth-child(1) { transition-delay: 0.07s; }
  .nav-links.open li:nth-child(2) { transition-delay: 0.13s; }
  .nav-links.open li:nth-child(3) { transition-delay: 0.19s; }
  .nav-links.open li:nth-child(4) { transition-delay: 0.25s; }
  .nav-links.open li:nth-child(5) { transition-delay: 0.31s; }
  .nav-links.open li:nth-child(6) { transition-delay: 0.37s; }
  .nav-links.open li:nth-child(7) { transition-delay: 0.43s; }
  .nav-links.open li:nth-child(8) { transition-delay: 0.49s; }
  .nav-links.open li:nth-child(9) { transition-delay: 0.55s; }
  .nav-link {
    display: flex;
    align-items: center;
    padding: 0.875rem 0.25rem;
    font-size: 1rem;
    min-height: 44px;
  }
  .nav-link::after { display: none; }
  .nav-cta { width: 100%; justify-content: center; }

  .nav-toggle {
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 0.75rem 0.5rem;
    min-width: 44px;
    min-height: 44px;
  }
  .nav-toggle span {
    display: block;
    width: 24px; height: 2px;
    background: var(--text-primary);
    transition: transform 0.3s ease, opacity 0.3s ease, background 0.3s ease;
    pointer-events: none;
  }
  .nav-toggle.open span:nth-child(1) { transform: translateY(7px) rotate(45deg); }
  .nav-toggle.open span:nth-child(2) { opacity: 0; transform: scaleX(0); }
  .nav-toggle.open span:nth-child(3) { transform: translateY(-7px) rotate(-45deg); }
  .nav-toggle.open span { background: var(--ember-3); }
}

/* ≤ 768px — footer stack */
@media (max-width: 768px) {
  .footer-grid { grid-template-columns: 1fr; gap: 2rem; }
  .footer-bottom { flex-direction: column; gap: 1rem; text-align: center; }
  .footer-bottom-links { justify-content: center; }
}

/* ≤ 480px — footer compact */
@media (max-width: 480px) {
  .footer { padding: 3rem 0 1.5rem; }
}
</style>

<script>
const nav = document.getElementById('nav');
const toggle = document.getElementById('navToggle');
const links = document.getElementById('navLinks');
const cursor = document.getElementById('cursorGlow');

// Nav scroll
window.addEventListener('scroll', () => {
  nav?.classList.toggle('scrolled', window.scrollY > 20);
});

// Mobile menu helpers
function openMenu() {
  links?.classList.add('open');
  toggle?.classList.add('open');
  toggle?.setAttribute('aria-expanded', 'true');
  toggle?.setAttribute('aria-label', 'Fermer le menu de navigation');
}
function closeMenu() {
  links?.classList.remove('open');
  toggle?.classList.remove('open');
  toggle?.setAttribute('aria-expanded', 'false');
  toggle?.setAttribute('aria-label', 'Ouvrir le menu de navigation');
}

toggle?.addEventListener('click', () => {
  links?.classList.contains('open') ? closeMenu() : openMenu();
});

// Close on nav link click (mobile UX)
links?.querySelectorAll('a').forEach(a => a.addEventListener('click', closeMenu));

// Close on Escape key
document.addEventListener('keydown', e => {
  if (e.key === 'Escape' && links?.classList.contains('open')) {
    closeMenu();
    toggle?.focus();
  }
});

// Close on outside click
document.addEventListener('click', e => {
  const navEl = document.getElementById('nav');
  if (navEl && !navEl.contains(e.target as Node) && links?.classList.contains('open')) {
    closeMenu();
  }
});

// Scroll fade-in
const observer = new IntersectionObserver((entries) => {
  entries.forEach(entry => {
    if (entry.isIntersecting) {
      entry.target.classList.add('visible');
      observer.unobserve(entry.target);
    }
  });
}, { threshold: 0.10 });
document.querySelectorAll('.fade-in').forEach(el => observer.observe(el));

// Auto-stagger grid/list items
[
  '.configs-grid > *', '.offers-grid > *', '.uc-grid > *',
  '.included-grid > *', '.process-steps > *', '.how-steps > *',
  '.problems-grid > *', '.tarifs-grid .tarif-row',
  '.contact-infos .info-block', '.stack-cols > *',
  '.projects-grid > *', '.values-grid > *', '.work-steps > *',
  '.intro-stats > *',
].forEach(sel => {
  document.querySelectorAll(sel).forEach((el, i) => {
    el.classList.add('fade-in');
    (el as HTMLElement).style.transitionDelay = `${i * 0.09}s`;
    observer.observe(el);
  });
});

// Section headings auto fade-in
document.querySelectorAll(
  '.section > .container > h2, .section > .container > .section-pre'
).forEach(el => {
  if (!el.classList.contains('fade-in')) {
    el.classList.add('fade-in');
    observer.observe(el);
  }
});

// Cursor glow — désactivé sur appareils tactiles
if (window.matchMedia('(hover: hover) and (pointer: fine)').matches) {
  document.addEventListener('mousemove', (e) => {
    if (cursor) {
      cursor.style.left = e.clientX + 'px';
      cursor.style.top = e.clientY + 'px';
      cursor.style.opacity = '1';
    }
  });
  document.addEventListener('mouseleave', () => {
    if (cursor) cursor.style.opacity = '0';
  });
}
</script>