---
import '../styles/global.css';
import { Image } from 'astro:assets';
import logo from '../images/logo2.png';
import EnvelopeLight from 'phosphor-astro/EnvelopeLight.astro';
import PhoneLight from 'phosphor-astro/PhoneLight.astro';

const { title = 'EmberFox', description = 'Solutions informatiques sur mesure' } = Astro.props;

const navLinks = [
  { href: '/', label: 'Accueil' },
  { href: '/emberfox-site/Sites-web', label: 'Sites Web' },
  { href: '/emberfox-site/Applications', label: 'Applications' },
  { href: '/emberfox-site/Montage-pc', label: 'Montage PC' },
  { href: '/emberfox-site/Depannage', label: 'Dépannage' },
  { href: '/emberfox-site/Contact', label: 'Contact' },
];

const currentPath = Astro.url.pathname;
---
<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title} | EmberFox</title>
  <meta name="description" content={description} />
  <link rel="icon" type="image/png" href="/logo.png" />
</head>
<body>

  <!-- CURSOR GLOW -->
  <div class="cursor-glow" id="cursorGlow"></div>

  <!-- NAV -->
  <nav class="nav" id="nav">
    <div class="nav-inner container">
      <a href="/" class="nav-logo">
        <Image src={logo} alt="EmberFox" width={36} height={45} class="nav-logo-img" format="png" />
        <span class="nav-logo-text"><span class="fire-text">EMBER</span>FOX</span>
      </a>

      <button class="nav-toggle" id="navToggle" aria-label="Menu">
        <span></span><span></span><span></span>
      </button>

      <ul class="nav-links" id="navLinks">
        {navLinks.map(link => (
          <li>
            <a
              href={link.href}
              class={`nav-link ${currentPath === link.href ? 'active' : ''}`}
            >
              {link.label}
            </a>
          </li>
        ))}
        <li><a href="/Contact" class="btn-fire nav-cta">Devis gratuit</a></li>
      </ul>
    </div>
  </nav>

  <main>
    <slot />
  </main>

  <!-- FOOTER -->
  <footer class="footer">
    <div class="footer-ember-line"></div>
    <div class="container">
      <div class="footer-grid">
        <div class="footer-brand">
          <div class="footer-logo-wrap">
            <Image src={logo} alt="EmberFox" width={45} height={54} class="footer-logo-img" format="png" />
            <span class="footer-brand-name display-font"><span class="fire-text">EMBER</span>FOX</span>
          </div>
          <p class="footer-tagline">Solutions informatiques<br/>sur mesure — Belgique</p>
          <div class="footer-socials">
            <a href="mailto:contact@emberfox.be" class="social-link" title="Email">
              <EnvelopeLight width={18} height={18} />
            </a>
            <a href="tel:+32000000000" class="social-link" title="Téléphone">
              <PhoneLight width={18} height={18} />
            </a>
          </div>
          <p class="footer-legal mono-font">© 2025 EmberFox</p>
        </div>
        <div class="footer-col">
          <p class="footer-heading display-font">Services</p>
          <ul>
            <li><a href="/Sites-web">Sites Web</a></li>
            <li><a href="/Applications">Applications</a></li>
            <li><a href="/Montage-pc">Montage PC</a></li>
            <li><a href="/Depannage">Dépannage</a></li>
          </ul>
        </div>
        <div class="footer-col">
          <p class="footer-heading display-font">Contact</p>
          <ul>
            <li><a href="mailto:contact@emberfox.be">contact@emberfox.be</a></li>
            <li><a href="tel:+32000000000">+32 000 00 00 00</a></li>
            <li><span style="color:var(--text-muted)">Namur, Belgique</span></li>
            <li><span style="color:var(--text-muted)">Lun–Sam · 9h–19h</span></li>
          </ul>
        </div>
      </div>
      <div class="footer-bottom">
        <span class="mono-font" style="color:var(--text-muted);font-size:0.75rem">Conçu avec feu & passion — <span class="fire-text">EmberFox</span></span>
        <div class="footer-bottom-links">
          <a href="#" class="mono-font" style="color:var(--text-muted);font-size:0.75rem;text-decoration:none;transition:color 0.2s">Mentions légales</a>
          <a href="#" class="mono-font" style="color:var(--text-muted);font-size:0.75rem;text-decoration:none;transition:color 0.2s">Confidentialité</a>
        </div>
      </div>
    </div>
  </footer>

</body>
</html>

<style>
/* CURSOR GLOW */
.cursor-glow {
  position: fixed;
  width: 300px;
  height: 300px;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(255, 80, 0, 0.06) 0%, transparent 70%);
  pointer-events: none;
  z-index: 9998;
  transform: translate(-50%, -50%);
  transition: opacity 0.3s;
  opacity: 0;
}

/* NAV */
.nav {
  position: fixed;
  top: 0; left: 0; right: 0;
  z-index: 100;
  padding: 1.25rem 0;
  transition: background 0.4s, backdrop-filter 0.4s, padding 0.3s, border-color 0.4s;
  border-bottom: 1px solid transparent;
}
.nav.scrolled {
  background: rgba(10, 8, 4, 0.88);
  backdrop-filter: blur(20px) saturate(180%);
  border-bottom-color: var(--dark-border);
  padding: 0.875rem 0;
}
.nav-inner {
  display: flex;
  align-items: center;
  justify-content: space-between;
}
.nav-logo {
  display: flex;
  align-items: center;
  gap: 0.75rem;
  text-decoration: none;
}
.nav-logo-img {
  filter: drop-shadow(0 0 8px rgba(255, 100, 0, 0.45));
  transition: filter 0.3s ease, transform 0.4s ease;
}
.nav-logo:hover .nav-logo-img {
  filter: drop-shadow(0 0 18px rgba(255, 130, 0, 0.9));
  transform: scale(1.1) rotate(-4deg);
}
.nav-logo-text {
  font-family: 'Bebas Neue', sans-serif;
  font-size: 1.5rem;
  letter-spacing: 0.1em;
  color: var(--text-primary);
}
.nav-links {
  display: flex;
  align-items: center;
  gap: 0.25rem;
  list-style: none;
}
.nav-link {
  padding: 0.5rem 0.875rem;
  color: var(--text-secondary);
  text-decoration: none;
  font-size: 0.875rem;
  font-weight: 500;
  letter-spacing: 0.05em;
  transition: color 0.2s;
  position: relative;
}
.nav-link::after {
  content: '';
  position: absolute;
  bottom: 0; left: 0.875rem; right: 0.875rem;
  height: 1px;
  background: var(--gradient-fire);
  transform: scaleX(0);
  transition: transform 0.25s cubic-bezier(0.4, 0, 0.2, 1);
  transform-origin: left;
}
.nav-link:hover, .nav-link.active { color: var(--text-primary); }
.nav-link:hover::after, .nav-link.active::after { transform: scaleX(1); }
.nav-cta { font-size: 0.9rem; padding: 0.6rem 1.25rem; margin-left: 0.5rem; }
.nav-toggle { display: none; }

/* FOOTER */
.footer {
  border-top: 1px solid var(--dark-border);
  padding: 4rem 0 2rem;
  margin-top: 4rem;
  position: relative;
  overflow: hidden;
}
.footer-ember-line {
  position: absolute;
  top: 0; left: 0; right: 0;
  height: 1px;
  background: var(--gradient-fire);
  opacity: 0.4;
}
.footer::after {
  content: '';
  position: absolute;
  bottom: -100px; left: 50%; transform: translateX(-50%);
  width: 800px; height: 300px;
  background: radial-gradient(ellipse, rgba(255, 100, 0, 0.04), transparent 70%);
  pointer-events: none;
}
.footer-grid {
  display: grid;
  grid-template-columns: 2fr 1fr 1fr;
  gap: 3rem;
  margin-bottom: 3rem;
}
.footer-brand { display: flex; flex-direction: column; gap: 1rem; }
.footer-logo-wrap {
  display: flex;
  align-items: center;
  gap: 0.875rem;
}
.footer-logo-img {
  filter: drop-shadow(0 0 10px rgba(255, 100, 0, 0.5));
  transition: filter 0.3s ease, transform 0.3s ease;
}
.footer-logo-wrap:hover .footer-logo-img {
  filter: drop-shadow(0 0 22px rgba(255, 130, 0, 0.85));
  transform: scale(1.05) rotate(-3deg);
}
.footer-brand-name {
  font-size: 1.6rem;
  letter-spacing: 0.1em;
  color: var(--text-primary);
}
.footer-tagline { color: var(--text-secondary); line-height: 1.6; font-size: 0.9rem; }
.footer-legal { color: var(--text-muted); font-size: 0.75rem; margin-top: 0.5rem; }
.footer-socials { display: flex; gap: 0.75rem; }
.social-link {
  display: flex; align-items: center; justify-content: center;
  width: 36px; height: 36px;
  border: 1px solid var(--dark-border);
  color: var(--text-muted);
  text-decoration: none;
  transition: border-color 0.2s, color 0.2s, background 0.2s;
  clip-path: polygon(0 0, calc(100% - 6px) 0, 100% 6px, 100% 100%, 6px 100%, 0 calc(100% - 6px));
}
.social-link:hover { border-color: var(--ember-2); color: var(--ember-3); background: rgba(255,140,0,0.06); }
.footer-heading { font-size: 1.1rem; color: var(--ember-3); margin-bottom: 1rem; }
.footer-col ul { list-style: none; display: flex; flex-direction: column; gap: 0.75rem; }
.footer-col ul li a {
  color: var(--text-secondary);
  text-decoration: none;
  font-size: 0.875rem;
  transition: color 0.2s, padding-left 0.2s;
  display: inline-block;
}
.footer-col ul li a:hover { color: var(--ember-3); padding-left: 4px; }
.footer-bottom {
  border-top: 1px solid var(--dark-border);
  padding-top: 1.5rem;
  display: flex;
  justify-content: space-between;
  align-items: center;
}
.footer-bottom-links { display: flex; gap: 1.5rem; }
.footer-bottom-links a:hover { color: var(--ember-3) !important; }

@media (max-width: 768px) {
  .nav-links { display: none; flex-direction: column; position: absolute; top: 100%; left: 0; right: 0; background: rgba(10,8,4,0.97); padding: 1.5rem 2rem; gap: 0.5rem; border-bottom: 1px solid var(--dark-border); backdrop-filter: blur(20px); }
  .nav-links.open { display: flex; }
  .nav-toggle { display: flex; flex-direction: column; gap: 5px; background: none; border: none; cursor: pointer; padding: 0.5rem; }
  .nav-toggle span { display: block; width: 24px; height: 2px; background: var(--text-primary); transition: 0.3s; }
  .footer-grid { grid-template-columns: 1fr; gap: 2rem; }
  .footer-bottom { flex-direction: column; gap: 1rem; text-align: center; }
  .footer-bottom-links { justify-content: center; }
}
</style>

<script>
const nav = document.getElementById('nav');
const toggle = document.getElementById('navToggle');
const links = document.getElementById('navLinks');
const cursor = document.getElementById('cursorGlow');

// Nav scroll
window.addEventListener('scroll', () => {
  nav?.classList.toggle('scrolled', window.scrollY > 20);
});

// Mobile menu
toggle?.addEventListener('click', () => {
  links?.classList.toggle('open');
});

// Cursor glow
document.addEventListener('mousemove', (e) => {
  if (cursor) {
    cursor.style.left = e.clientX + 'px';
    cursor.style.top = e.clientY + 'px';
    cursor.style.opacity = '1';
  }
});
document.addEventListener('mouseleave', () => {
  if (cursor) cursor.style.opacity = '0';
});
</script>