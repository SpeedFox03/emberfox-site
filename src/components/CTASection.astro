---
interface Props {
  centered?: boolean;
}
const { centered = false } = Astro.props;
---
<section class="section cta-sec">
  <div class={`container ${centered ? 'cta-center' : 'cta-split'}`}>
    <slot />
  </div>
</section>

<style>
.cta-sec { background: var(--dark-card); border-top: 1px solid var(--dark-border); }
.cta-center { text-align: center; max-width: 640px; }
.cta-split { display: flex; align-items: center; justify-content: space-between; gap: 2rem; flex-wrap: wrap; }
@media (max-width: 480px) {
  .cta-split { flex-direction: column; align-items: flex-start; gap: 1.5rem; }
}
</style>
